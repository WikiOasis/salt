{%- set nginx = salt['pillar.get']('nginx', {}) %}
{%- set csp = nginx.get('csp_header', '') %}
{%- set permission_policy = nginx.get('permission_policy_header', '') %}
# salt managed, do not modify manually
root /srv/mediawiki;
index index.php index.html index.htm;
client_max_body_size 128M;
proxy_hide_header Referrer-Policy;
add_header Referrer-Policy strict-origin-when-cross-origin;
add_header X-Permitted-Cross-Domain-Policies "none";
add_header Cross-Origin-Opener-Policy "same-origin";
add_header Cache-Tag $cache_tag;
{% if csp %}
add_header Content-Security-Policy "{{ csp }}" always;
{% endif %}
{% if permission_policy %}
add_header Permissions-Policy "{{ permission_policy }}" always;
{% endif %}

location = /robots.txt {
  try_files $uri /w/config/robots.php;
}

location = /sitemap.xml {
  rewrite ^ /w/sitemap.php last;
}

location ~ ^/sitemaps/(.+\.xml)$ {
  rewrite ^/sitemaps/(.+\.xml)$ /w/sitemap.php?sitemap=$1 last;
}

location ~ ^/images/.*\.php$ {
  deny all;
}

location ~ ^/images/(.*)$ {
  return 301 https://static.wikioasis.org/$1$is_args$args;
}

location / {
  try_files $uri /w/index.php$is_args$args;
}

location /wiki/ {
  rewrite ^/wiki/([^\?]*) /w/index.php?title=$1&$args last;
}

location ~ ^/w/img_auth.php {
  rewrite ^/w/img_auth.php/(.*)$ /w/img_auth.php last;

  include snippets/fastcgi-php.conf;
  fastcgi_pass 127.0.0.1:9000;
  fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
  fastcgi_param MW_ENV production;
  include fastcgi_params;
}

location ~ /w/.*\.php$ {
  include snippets/fastcgi-php.conf;
  fastcgi_pass 127.0.0.1:9000;
  fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
  fastcgi_param MW_ENV production;
  include fastcgi_params;
}

location ~ ^/w/rest\.php(/|$) {
  include snippets/fastcgi-php.conf;
  fastcgi_pass 127.0.0.1:9000;
  fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
  fastcgi_param MW_ENV production;
  include fastcgi_params;
}

location ~ ^/w/(cw_cache|docs|cache|config|includes|vendor|language|maintenance|tests|mw-config)/ {
  deny all;
}

location ~ /w/(composer\.json|composer\.lock|LocalSettings\.php)$ { deny all; }

error_log /var/log/nginx/mediawiki_error.log;
access_log /var/log/nginx/mediawiki_access.log;
