# Managed by Salt — do not edit manually.
[server]
http_port = 3000
domain = grafana.wikioasis.org
root_url = %(protocol)s://%(domain)s/
serve_from_sub_path = false

[database]
type = sqlite3
path = grafana.db

[security]
admin_user = {{ admin_user }}
admin_password = {{ admin_pass }}

[users]
allow_sign_up = false

[auth.anonymous]
enabled = false

[log]
mode = console
level = info