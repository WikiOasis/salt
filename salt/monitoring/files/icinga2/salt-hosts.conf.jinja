
{%- set hosts = salt['pillar.get']('dns_hosts', {}) %}
# Managed by Salt — do not edit manually.

# ── Host template ──────────────────────────────────────────────────────────────

template Host "generic-salt-host" {
  check_command        = "hostalive"
  max_check_attempts   = 1
  check_interval       = 1m
  retry_interval       = 10s
  enable_notifications = true
  enable_active_checks = true
}

template Service "generic-salt-service" {
  max_check_attempts   = 1
  enable_notifications = true
}

# ── Notification user ─────────────────────────────────────────────────────────

object User "webhook-notify" {
  enable_notifications = true
}

# ── Per-host objects ──────────────────────────────────────────────────────────

{%- for hostname, host_data in hosts.items() %}
{%- set is_proxy       = hostname.startswith('proxy') %}
{%- set is_db          = hostname.startswith('db') %}
{%- set is_monitoring  = hostname.startswith('monitoring') %}
{%- set is_metal       = hostname.startswith('metal') %}
{%- set is_redis       = hostname.startswith('redis') %}
{%- set is_opensearch  = hostname.startswith('opensearch') %}
{%- set is_salt_master = hostname.startswith('salt') %}
{%- set is_mw          = hostname.startswith('mw') or hostname.startswith('staging') %}
{%- set has_nginx      = host_data.get('nginx', is_monitoring or is_mw) %}
{%- set nrpe_svcs      = ['load', 'disk_root', 'procs', 'swap', 'mem', 'apt', 'salt_minion']
                         + (['disk_srv'] if is_db else [])
                         + (['smart', 'raid'] if is_metal else [])
                         + (['php_fpm', 'php_errors', 'mediawiki'] if is_mw else [])
                         + (['opensearch'] if is_opensearch else []) %}
{%- set notif_svcs     = ['ssh'] + nrpe_svcs
                         + (['haproxy', 'haproxy_backends'] if is_proxy else [])
                         + (['http'] if is_monitoring else [])
                         + (['mariadb'] if is_db else [])
                         + (['nginx_errors', 'nginx_4xx_errors'] if has_nginx else [])
                         + (['redis'] if is_redis else [])
                         + (['salt_master'] if is_salt_master else []) %}

# -- {{ hostname }} ({{ host_data.ip }}) ----------------------------------------

object Host "{{ hostname }}" {
  import "generic-salt-host"
  address = "{{ host_data.ip }}"
  vars.os = "Linux"
}

object Service "ssh" {
  import         "generic-salt-service"
  host_name      = "{{ hostname }}"
  check_command  = "ssh"
  check_interval = 5m
  retry_interval = 10s
}

{%- if is_proxy %}
object Service "haproxy" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_haproxy"
  check_interval    = 1m
  retry_interval    = 10s
}

object Service "haproxy_backends" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_haproxy_backends"
  check_interval    = 1m
  retry_interval    = 10s
}
{%- elif is_monitoring %}
object Service "http" {
  import         "generic-salt-service"
  host_name      = "{{ hostname }}"
  check_command  = "http"
  vars.http_uri  = "/"
  check_interval = 1m
  retry_interval = 10s
}
{%- endif %}

{%- if has_nginx %}
object Service "nginx_errors" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_nginx_errors"
  check_interval    = 1m
  retry_interval    = 10s
}

object Service "nginx_4xx_errors" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_nginx_4xx_errors"
  check_interval    = 1m
  retry_interval    = 10s
}
{%- endif %}

{%- if is_db %}
object Service "mariadb" {
  import                "generic-salt-service"
  host_name             = "{{ hostname }}"
  check_command         = "mysql"
  vars.mysql_hostname   = "$address$"
  vars.mysql_port       = 3306
  vars.mysql_username   = "icinga_monitor"
  vars.mysql_password   = "{{ salt['pillar.get']('monitoring:monitoring_db_password') }}"
  check_interval        = 1m
  retry_interval        = 10s
}
{%- endif %}

object Service "load" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_load"
  check_interval    = 1m
  retry_interval    = 10s
}

object Service "disk_root" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_disk_root"
  check_interval    = 5m
  retry_interval    = 1m
}

object Service "procs" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_procs"
  check_interval    = 5m
  retry_interval    = 1m
}

object Service "swap" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_swap"
  check_interval    = 5m
  retry_interval    = 1m
}

object Service "mem" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_mem"
  check_interval    = 1m
  retry_interval    = 10s
}

object Service "apt" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_apt"
  check_interval    = 30m
  retry_interval    = 5m
}

{%- if is_metal %}
object Service "smart" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_smart"
  check_interval    = 15m
  retry_interval    = 5m
}

object Service "raid" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_raid"
  check_interval    = 5m
  retry_interval    = 1m
}
{%- endif %}

{%- if is_db %}
object Service "disk_srv" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_disk_srv"
  check_interval    = 5m
  retry_interval    = 1m
}
{%- endif %}

object Service "salt_minion" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_salt_minion"
  check_interval    = 1m
  retry_interval    = 10s
}

{%- if is_salt_master %}
object Service "salt_master" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_salt_master"
  check_interval    = 1m
  retry_interval    = 10s
}
{%- endif %}

{%- if is_redis %}
object Service "redis" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_redis"
  check_interval    = 1m
  retry_interval    = 10s
}
{%- endif %}

{%- if is_opensearch %}
object Service "opensearch" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_opensearch"
  check_interval    = 1m
  retry_interval    = 10s
}
{%- endif %}

{%- if is_mw %}
object Service "php_fpm" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_php_fpm"
  check_interval    = 1m
  retry_interval    = 10s
}

object Service "php_errors" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_php_errors"
  check_interval    = 1m
  retry_interval    = 10s
}

object Service "mediawiki" {
  import            "generic-salt-service"
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_mediawiki"
  check_interval    = 1m
  retry_interval    = 10s
}
{%- endif %}

{%- for svc in notif_svcs %}
object Notification "discord-svc-{{ hostname }}-{{ svc }}" {
  host_name    = "{{ hostname }}"
  service_name = "{{ svc }}"
  command      = "notify-service-by-discord"
  users        = [ "webhook-notify" ]
  states       = [ OK, Warning, Critical, Unknown ]
  types        = [ Problem, Recovery, Acknowledgement, FlappingStart, FlappingEnd ]
}

object Notification "slack-svc-{{ hostname }}-{{ svc }}" {
  host_name    = "{{ hostname }}"
  service_name = "{{ svc }}"
  command      = "notify-service-by-slack"
  users        = [ "webhook-notify" ]
  states       = [ OK, Warning, Critical, Unknown ]
  types        = [ Problem, Recovery, Acknowledgement, FlappingStart, FlappingEnd ]
}

object Notification "incidentio-svc-{{ hostname }}-{{ svc }}" {
  host_name    = "{{ hostname }}"
  service_name = "{{ svc }}"
  command      = "notify-service-by-incidentio"
  users        = [ "webhook-notify" ]
  states       = [ OK, Warning, Critical, Unknown ]
  types        = [ Problem, Recovery ]
}
{%- endfor %}

object Notification "discord-host-{{ hostname }}" {
  host_name = "{{ hostname }}"
  command   = "notify-host-by-discord"
  users     = [ "webhook-notify" ]
  states    = [ Up, Down ]
  types     = [ Problem, Recovery, Acknowledgement, FlappingStart, FlappingEnd ]
}

object Notification "slack-host-{{ hostname }}" {
  host_name = "{{ hostname }}"
  command   = "notify-host-by-slack"
  users     = [ "webhook-notify" ]
  states    = [ Up, Down ]
  types     = [ Problem, Recovery, Acknowledgement, FlappingStart, FlappingEnd ]
}

object Notification "incidentio-host-{{ hostname }}" {
  host_name = "{{ hostname }}"
  command   = "notify-host-by-incidentio"
  users     = [ "webhook-notify" ]
  states    = [ Up, Down ]
  types     = [ Problem, Recovery ]
}

{%- endfor %}
