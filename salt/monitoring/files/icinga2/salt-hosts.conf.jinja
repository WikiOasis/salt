{%- set hosts = salt['pillar.get']('dns_hosts', {}) %}
# Managed by Salt — do not edit manually.

# ── Host template ──────────────────────────────────────────────────────────────

template Host "generic-salt-host" {
  check_command        = "hostalive"
  max_check_attempts   = 3
  check_interval       = 1m
  retry_interval       = 30s
  enable_notifications = true
  enable_active_checks = true
}

# ── Notification user ─────────────────────────────────────────────────────────

object User "webhook-notify" {
  enable_notifications = true
}

# ── Per-host objects ──────────────────────────────────────────────────────────

{%- for hostname, host_data in hosts.items() %}
{%- set is_proxy      = hostname.startswith('proxy') %}
{%- set is_db         = hostname.startswith('db') %}
{%- set is_monitoring = hostname.startswith('monitoring') %}
{%- set is_metal      = hostname.startswith('metal') %}
{%- set has_nginx     = host_data.get('nginx', is_monitoring) %}
{%- set nrpe_svcs     = ['load', 'disk_root', 'procs', 'swap', 'mem', 'apt']
                        + (['disk_srv'] if is_db else [])
                        + (['smart', 'raid'] if is_metal else []) %}
{%- set notif_svcs    = nrpe_svcs
                        + (['haproxy', 'haproxy_backends'] if is_proxy else [])
                        + (['nginx_errors'] if has_nginx else []) %}

# -- {{ hostname }} ({{ host_data.ip }}) ----------------------------------------

object Host "{{ hostname }}" {
  import "generic-salt-host"
  address = "{{ host_data.ip }}"
  vars.os = "Linux"
}

object Service "ssh" {
  host_name      = "{{ hostname }}"
  check_command  = "ssh"
  check_interval = 5m
  retry_interval = 1m
}

{%- if is_proxy %}
object Service "haproxy" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_haproxy"
  check_interval    = 1m
  retry_interval    = 30s
}

object Service "haproxy_backends" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_haproxy_backends"
  check_interval    = 1m
  retry_interval    = 30s
}
{%- elif is_monitoring %}
object Service "http" {
  host_name      = "{{ hostname }}"
  check_command  = "http"
  vars.http_uri  = "/"
  check_interval = 5m
  retry_interval = 1m
}
{%- endif %}

{%- if has_nginx %}
object Service "nginx_errors" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_nginx_errors"
  check_interval    = 5m
  retry_interval    = 1m
}
{%- endif %}

{%- if is_db %}
object Service "mysql_port" {
  host_name      = "{{ hostname }}"
  check_command  = "tcp"
  vars.tcp_port  = 3306
  check_interval = 5m
  retry_interval = 1m
}
{%- endif %}

object Service "load" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_load"
  check_interval    = 1m
  retry_interval    = 30s
}

object Service "disk_root" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_disk_root"
  check_interval    = 5m
  retry_interval    = 1m
}

object Service "procs" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_procs"
  check_interval    = 5m
  retry_interval    = 1m
}

object Service "swap" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_swap"
  check_interval    = 5m
  retry_interval    = 1m
}

object Service "mem" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_mem"
  check_interval    = 1m
  retry_interval    = 30s
}

object Service "apt" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_apt"
  check_interval    = 30m
  retry_interval    = 5m
}

{%- if is_metal %}
object Service "smart" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_smart"
  check_interval    = 15m
  retry_interval    = 5m
}

object Service "raid" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_raid"
  check_interval    = 5m
  retry_interval    = 1m
}
{%- endif %}

{%- if is_db %}
object Service "disk_srv" {
  host_name         = "{{ hostname }}"
  check_command     = "nrpe"
  vars.nrpe_command = "check_disk_srv"
  check_interval    = 5m
  retry_interval    = 1m
}
{%- endif %}

{%- for svc in notif_svcs %}
object Notification "discord-svc-{{ hostname }}-{{ svc }}" {
  host_name    = "{{ hostname }}"
  service_name = "{{ svc }}"
  command      = "notify-service-by-discord"
  users        = [ "webhook-notify" ]
  states       = [ OK, Warning, Critical, Unknown ]
  types        = [ Problem, Recovery, Acknowledgement, FlappingStart, FlappingEnd ]
}

object Notification "slack-svc-{{ hostname }}-{{ svc }}" {
  host_name    = "{{ hostname }}"
  service_name = "{{ svc }}"
  command      = "notify-service-by-slack"
  users        = [ "webhook-notify" ]
  states       = [ OK, Warning, Critical, Unknown ]
  types        = [ Problem, Recovery, Acknowledgement, FlappingStart, FlappingEnd ]
}
{%- endfor %}

object Notification "discord-host-{{ hostname }}" {
  host_name = "{{ hostname }}"
  command   = "notify-host-by-discord"
  users     = [ "webhook-notify" ]
  states    = [ Up, Down ]
  types     = [ Problem, Recovery, Acknowledgement, FlappingStart, FlappingEnd ]
}

object Notification "slack-host-{{ hostname }}" {
  host_name = "{{ hostname }}"
  command   = "notify-host-by-slack"
  users     = [ "webhook-notify" ]
  states    = [ Up, Down ]
  types     = [ Problem, Recovery, Acknowledgement, FlappingStart, FlappingEnd ]
}

{%- endfor %}
