# Managed by Salt — do not edit manually.
global:
  scrape_interval:     60s
  evaluation_interval: 60s

scrape_configs:
  - job_name: 'node'
    file_sd_configs:
      - files: ['/etc/prometheus/file_sd/node.json']
        refresh_interval: 5m

  - job_name: 'mysqld'
    file_sd_configs:
      - files: ['/etc/prometheus/file_sd/mysqld.json']
        refresh_interval: 5m

  - job_name: 'haproxy'
    file_sd_configs:
      - files: ['/etc/prometheus/file_sd/haproxy.json']
        refresh_interval: 5m

  - job_name: 'redis'
    file_sd_configs:
      - files: ['/etc/prometheus/file_sd/redis.json']
        refresh_interval: 5m

  - job_name: 'statsd'
    file_sd_configs:
      - files: ['/etc/prometheus/file_sd/statsd.json']
        refresh_interval: 5m

  - job_name: 'phpfpm'
    file_sd_configs:
      - files: ['/etc/prometheus/file_sd/phpfpm.json']
        refresh_interval: 5m

  - job_name: 'opensearch'
    file_sd_configs:
      - files: ['/etc/prometheus/file_sd/opensearch.json']
        refresh_interval: 5m