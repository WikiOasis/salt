#!/bin/bash
# Streams binary logs from the local MariaDB instance to /var/backups/mariadb/binlogs/.
# Runs as a systemd service with Restart=always so it resumes automatically.
{%- set backup = salt['pillar.get']('mariadb:backup', {}) %}
BACKUP_DIR=/var/backups/mariadb/binlogs
MYSQL_USER="{{ backup.get('user', 'mariadb_backup') }}"
MYSQL_PASS="{{ backup.get('password', '') }}"

mkdir -p "$BACKUP_DIR"

# Resume from the latest local binlog file; fall back to current master position.
LATEST=$(ls -t "$BACKUP_DIR"/mysql-bin.[0-9]* 2>/dev/null | head -1)
if [ -n "$LATEST" ]; then
    BINLOG=$(basename "$LATEST")
else
    BINLOG=$(mysql -u"$MYSQL_USER" -p"$MYSQL_PASS" \
        --skip-column-names -e "SHOW MASTER STATUS" | awk '{print $1}')
fi

if [ -z "$BINLOG" ]; then
    echo "Error: binary logging is not enabled or could not determine binlog file" >&2
    exit 1
fi

exec mariadb-binlog \
    --read-from-remote-server \
    --stop-never \
    --raw \
    --stop-never-slave-server-id=65535 \
    --result-file="$BACKUP_DIR/" \
    --user="$MYSQL_USER" \
    --password="$MYSQL_PASS" \
    "$BINLOG"
