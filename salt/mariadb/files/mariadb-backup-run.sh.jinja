#!/bin/bash
# Streams full or incremental mariabackup directly to the remote backup server via SSH.
#
# Layout on the remote (one self-contained "set" per weekly full so a set can be
# restored to any point on its own — base + the incrementals that chain off it):
#   $REMOTE_PATH/$HOST/sets/<SET_ID>/base/                  (the weekly full)
#   $REMOTE_PATH/$HOST/sets/<SET_ID>/incremental/<DATE>/    (incrementals for that week)
#   $REMOTE_PATH/$HOST/sets/latest -> <newest SET_ID>       (convenience symlink)
# SET_ID is the timestamp of the full that opened the set (YYYYMMDD-HHMMSS).
# Old sets beyond mariadb:backup:retain_sets (default 4) are pruned after a full.
#
# No backup data is written to local disk — only small state files are kept:
#   /var/backups/mariadb/xtrabackup_checkpoints  (LSN for next incremental)
#   /var/backups/mariadb/current_set             (SET_ID incrementals chain into)
#   /var/backups/mariadb/last_full_backup        (epoch of last full)
#   /var/backups/mariadb/last_backup             (epoch of last backup of any kind)
# Usage: mariadb-backup-run.sh [full|incremental]
{%- set backup = salt['pillar.get']('mariadb:backup', {}) %}
{%- set dest = backup.get('destination', {}) %}
{%- set discord = salt['pillar.get']('notifications:discord_webhook_url', '') %}
{%- set slack = salt['pillar.get']('notifications:slack_webhook_url', '') %}
{%- set compress = backup.get('compress', true) %}
set -euo pipefail
ulimit -n 524288
MODE="${1:-incremental}"
STATE_DIR=/var/backups/mariadb

# Serialize backups. A busy DB's incremental can run for the better part of an
# hour; without a lock a manual rerun or an overrun into the next scheduled run
# would start a second mariabackup against the same state files and corrupt the
# LSN tracking. Non-blocking: if one is already running we just skip this run.
LOCK_FILE=/run/mariadb-backup.lock
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Another backup is already running; skipping"
    exit 0
fi
CHECKPOINTS="$STATE_DIR/xtrabackup_checkpoints"
CURRENT_SET_FILE="$STATE_DIR/current_set"
LAST_FULL="$STATE_DIR/last_full_backup"
LAST_BACKUP="$STATE_DIR/last_backup"
MYSQL_USER="{{ backup.get('user', 'mariadb_backup') }}"
MYSQL_PASS="{{ backup.get('password', '') }}"
REMOTE_USER="{{ dest.get('user', '') }}"
REMOTE_HOST="{{ dest.get('host', '') }}"
REMOTE_PATH="{{ dest.get('path', '/backup/mariadb') }}"
RETAIN_SETS="{{ backup.get('retain_sets', 4) }}"
SSH_KEY=/etc/mariadb-backup/ssh_key
HOST=$(hostname -s)
SETS_DIR="$REMOTE_PATH/$HOST/sets"
START=$(date +%s)

DISCORD_WEBHOOK_URL="{{ discord }}"
SLACK_WEBHOOK_URL="{{ slack }}"

# Prefer fast AEAD ciphers: the default cipher is often the throughput bottleneck
# on a busy link, and the SSH transfer is what gates how long a full takes (and
# therefore how much redo must be held — see the innodb_log_file_size sizing).
SSH="ssh -i $SSH_KEY -o StrictHostKeyChecking=no -o BatchMode=yes -o Ciphers=aes128-gcm@openssh.com,chacha20-poly1305@openssh.com,aes128-ctr $REMOTE_USER@$REMOTE_HOST"

# Compress the stream in transit so the SSH transfer moves far fewer bytes, which
# shortens the backup window (the real fix for redo-log wrap on large/busy DBs).
# Data is decompressed on the remote, so backups are STORED UNCOMPRESSED and the
# restore procedure is unchanged. zstd -T0 uses all cores; level 3 is a fast,
# high-ratio default. Set mariadb:backup:compress to false to disable (e.g. if the
# remote lacks zstd). DECOMPRESS is a remote-side pipeline prefix (note trailing |).
{%- if compress %}
COMPRESS="zstd -T0 -3"
DECOMPRESS="zstd -dc -T0 | "
{%- else %}
COMPRESS="cat"
DECOMPRESS=""
{%- endif %}

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }

notify() {
    local emoji="$1" text="$2"
    local msg="${emoji} [${HOST}] ${text}"
    if [ -n "$DISCORD_WEBHOOK_URL" ]; then
        jq -n --arg m "$msg" '{username:"Backup",content:$m}' \
        | curl -sSL --max-time 30 -X POST -H "Content-Type: application/json" -d @- \
            "$DISCORD_WEBHOOK_URL" || true
    fi
    if [ -n "$SLACK_WEBHOOK_URL" ]; then
        jq -n --arg m "$msg" '{text:$m}' \
        | curl -sSL --max-time 30 -X POST -H "Content-Type: application/json" -d @- \
            "$SLACK_WEBHOOK_URL" || true
    fi
}

on_exit() {
    local code=$?
    # Clean up any per-run --extra-lsndir temp dirs a failed backup left behind.
    rm -rf "$STATE_DIR"/lsn.* 2>/dev/null || true
    if [ $code -ne 0 ]; then
        local elapsed=$(( $(date +%s) - START ))
        notify ":x:" "${MODE} backup FAILED after ${elapsed}s (exit ${code})"
    fi
}
trap on_exit EXIT

remote_size() {
    # Best-effort; never let a transient du/ssh hiccup fail an otherwise-good
    # backup (the data is already safely on the remote by the time this runs).
    $SSH "du -sh '$1' 2>/dev/null" | cut -f1 || true
}

# Record the checkpoint LSN from the backup that just ran, read from a fresh
# per-run --extra-lsndir (passed in as $1). We deliberately do NOT read a streamed
# xtrabackup_checkpoints from the remote: mariabackup does not emit that file into
# the --stream=xbstream output here (confirmed — it never lands on the remote), so
# every run silently fell back to a full. --extra-lsndir writes the checkpoints
# locally by the local mariabackup process regardless of the stream destination.
#
# The earlier "extra-lsndir is stale" problem came from reusing a *persistent*
# lsndir: a backup that died before writing checkpoints left an old to_lsn behind,
# so the next incremental chained from an ever-older LSN until it ballooned. A fresh
# mktemp dir per run already prevents that, so the only thing we reject here is a
# to_lsn that goes *backwards* past where this backup started ($2, default 0) —
# a genuine anomaly. Note an idle DB legitimately reports an UNCHANGED checkpoint
# to_lsn (InnoDB only advances it on write activity), so equal is fine and must be
# accepted, else every backup on a quiet DB would fall back to a needless full.
save_checkpoints() {
    local lsndir="$1" min_lsn="${2:-0}"
    # MariaDB 11.x mariabackup writes mariadb_backup_checkpoints; older builds
    # (and Percona xtrabackup) used xtrabackup_checkpoints. Accept whichever exists.
    local cpfile=""
    local name
    for name in mariadb_backup_checkpoints xtrabackup_checkpoints; do
        if [ -f "$lsndir/$name" ]; then cpfile="$lsndir/$name"; break; fi
    done
    if [ -z "$cpfile" ]; then
        log "WARNING: mariabackup wrote no checkpoints to ${lsndir} — NEXT RUN WILL DO A FULL"
        log "WARNING:   dir contents: $(ls -a "$lsndir" 2>/dev/null | tr '\n' ' ')"
        rm -f "$CHECKPOINTS"
        return 0
    fi
    local new_lsn; new_lsn=$(awk '/^to_lsn/{print $3}' "$cpfile")
    if ! [[ "$new_lsn" =~ ^[0-9]+$ ]]; then
        log "WARNING: checkpoints ${cpfile} has no valid to_lsn ('${new_lsn}') — NEXT RUN WILL DO A FULL"
        log "WARNING:   file contents: $(tr '\n' ' ' < "$cpfile")"
        rm -f "$CHECKPOINTS"
        return 0
    fi
    if [ "$new_lsn" -lt "$min_lsn" ]; then
        log "WARNING: checkpoint to_lsn (${new_lsn}) went BACKWARDS past ${min_lsn} — anomalous; NEXT RUN WILL DO A FULL"
        rm -f "$CHECKPOINTS"
        return 0
    fi
    cp "$cpfile" "$CHECKPOINTS"
    log "Saved checkpoints (to_lsn=${new_lsn}); next incremental will chain from here"
}

# Keep only the newest $RETAIN_SETS sets on the remote; remove older ones.
# Sets are named by timestamp so a lexical sort is a chronological sort.
prune_old_sets() {
    if ! [[ "$RETAIN_SETS" =~ ^[0-9]+$ ]] || [ "$RETAIN_SETS" -le 0 ]; then
        log "Set retention disabled (retain_sets='${RETAIN_SETS}'); keeping all sets"
        return 0
    fi
    local old_sets
    old_sets=$($SSH "ls -1d '$SETS_DIR'/[0-9]*-[0-9]* 2>/dev/null | sort | head -n -${RETAIN_SETS}" || true)
    if [ -z "$old_sets" ]; then
        log "Retention: nothing to prune (keeping newest ${RETAIN_SETS} set(s))"
        return 0
    fi
    log "Retention: pruning $(echo "$old_sets" | wc -l | tr -d ' ') old set(s), keeping newest ${RETAIN_SETS}:"
    while IFS= read -r s; do log "  removing ${s}"; done <<< "$old_sets"
    if ! echo "$old_sets" | $SSH "xargs -r rm -rf"; then
        log "WARNING: failed to prune one or more old sets (continuing)"
    fi
}

run_full() {
    local set_id; set_id=$(date +%Y%m%d-%H%M%S)
    local set_dir="$SETS_DIR/$set_id"
    local lsndir; lsndir=$(mktemp -d "$STATE_DIR/lsn.XXXXXX")
    log "Starting streamed FULL backup — opening new set ${set_id}"
    log "  remote base dir: ${set_dir}/base"
    $SSH "mkdir -p '$set_dir/base'"

    mariabackup --backup --stream=xbstream \
        --extra-lsndir="$lsndir" \
        --open-files-limit=524288 \
        --user="$MYSQL_USER" --password="$MYSQL_PASS" \
    | $COMPRESS \
    | $SSH "${DECOMPRESS}mbstream -x -C '$set_dir/base/'"

    save_checkpoints "$lsndir"
    rm -rf "$lsndir"

    # Point subsequent incrementals at this set, and update the convenience symlink.
    echo "$set_id" > "$CURRENT_SET_FILE"
    log "Current backup set is now ${set_id}; incrementals will chain into it"
    $SSH "ln -sfn '$set_dir' '$SETS_DIR/latest'" \
        || log "WARNING: could not update '${SETS_DIR}/latest' symlink"

    local now; now=$(date +%s)
    echo "$now" > "$LAST_FULL"
    echo "$now" > "$LAST_BACKUP"

    local elapsed=$(( now - START ))
    local size; size=$(remote_size "$set_dir/base/")
    log "Full backup complete — set: ${set_id}, size: ${size}, duration: ${elapsed}s"
    notify ":white_check_mark:" "full backup complete (set ${set_id}) — size: ${size}, duration: ${elapsed}s"

    prune_old_sets
}

run_incremental() {
    log "Evaluating incremental preconditions"

    # An incremental must chain onto an existing set's base. No recorded set means
    # nothing for it to chain onto, so we have to take a full first.
    if [ ! -f "$CURRENT_SET_FILE" ]; then
        log "No current set recorded (${CURRENT_SET_FILE} missing); running FULL backup first"
        run_full
        return
    fi
    local set_id; set_id=$(cat "$CURRENT_SET_FILE")
    local set_dir="$SETS_DIR/$set_id"
    log "Current set: ${set_id} (${set_dir})"

    if [ ! -f "$CHECKPOINTS" ]; then
        log "No checkpoints file at ${CHECKPOINTS} — no LSN to chain from; running FULL backup first"
        run_full
        return
    fi
    log "Checkpoints file ${CHECKPOINTS} contents:"
    while IFS= read -r line; do log "    ${line}"; done < "$CHECKPOINTS"

    local last_full_epoch; last_full_epoch=$(cat "$LAST_FULL" 2>/dev/null || echo 0)
    local full_age=$(( ($(date +%s) - last_full_epoch) / 86400 ))
    log "Last full backup was ${full_age}d ago (epoch ${last_full_epoch})"
    if [ "$full_age" -ge 7 ]; then
        log "Full backup is ${full_age}d old (>=7d, weekly run missed); running FULL backup first"
        run_full
        return
    fi

    local to_lsn; to_lsn=$(awk '/^to_lsn/{print $3}' "$CHECKPOINTS")
    if ! [[ "$to_lsn" =~ ^[0-9]+$ ]]; then
        log "Checkpoints file has no valid to_lsn ('${to_lsn}'); running FULL backup"
        rm -f "$CHECKPOINTS"
        run_full
        return
    fi
    local DATE; DATE=$(date +%Y%m%d-%H%M%S)
    local inc_dir="$set_dir/incremental/$DATE"
    local lsndir; lsndir=$(mktemp -d "$STATE_DIR/lsn.XXXXXX")

    log "All preconditions met; starting streamed INCREMENTAL backup"
    log "  set: ${set_id}, from LSN: ${to_lsn}"
    log "  remote incremental dir: ${inc_dir}"
    $SSH "mkdir -p '$inc_dir'"

    if ! { mariabackup --backup --stream=xbstream \
        --incremental-lsn="$to_lsn" \
        --extra-lsndir="$lsndir" \
        --open-files-limit=524288 \
        --user="$MYSQL_USER" --password="$MYSQL_PASS" \
    | $COMPRESS \
    | $SSH "${DECOMPRESS}mbstream -x -C '$inc_dir/'"; }; then
        log "Incremental backup failed (LSN ${to_lsn} incompatible with current server state); falling back to FULL backup"
        rm -f "$CHECKPOINTS"; rm -rf "$lsndir"
        $SSH "rm -rf '$inc_dir'"
        run_full
        return
    fi

    # Advance the checkpoint so the next incremental chains from this one. Require
    # the new to_lsn to advance past where we started ($to_lsn), else it's stale.
    save_checkpoints "$lsndir" "$to_lsn"
    rm -rf "$lsndir"

    local now; now=$(date +%s)
    echo "$now" > "$LAST_BACKUP"

    local elapsed=$(( now - START ))
    local size; size=$(remote_size "$inc_dir/")
    log "Incremental backup complete — set: ${set_id}, dir: ${DATE}, size: ${size}, duration: ${elapsed}s"
    notify ":white_check_mark:" "incremental backup complete (set ${set_id}) — size: ${size}, duration: ${elapsed}s"
}

log "mariadb-backup-run starting: mode=${MODE}, host=${HOST}, remote=${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_PATH}, retain_sets=${RETAIN_SETS}"

case "$MODE" in
    full)        run_full ;;
    incremental) run_incremental ;;
    *)           echo "Usage: $0 [full|incremental]" >&2; exit 1 ;;
esac