#!/bin/bash
# Runs a full or incremental mariabackup and rsyncs the result to the backup server.
# Usage: mariadb-backup-run.sh [full|incremental]
{%- set backup = salt['pillar.get']('mariadb:backup', {}) %}
{%- set dest = backup.get('destination', {}) %}
{%- set discord = salt['pillar.get']('notifications:discord_webhook_url', '') %}
{%- set slack = salt['pillar.get']('notifications:slack_webhook_url', '') %}
set -euo pipefail

MODE="${1:-incremental}"
BACKUP_BASE=/var/backups/mariadb
BASE_DIR="$BACKUP_BASE/base"
INCR_BASE="$BACKUP_BASE/incremental"
MYSQL_USER="{{ backup.get('user', 'mariadb_backup') }}"
MYSQL_PASS="{{ backup.get('password', '') }}"
REMOTE_USER="{{ dest.get('user', '') }}"
REMOTE_HOST="{{ dest.get('host', '') }}"
REMOTE_PATH="{{ dest.get('path', '/backup/mariadb') }}"
SSH_KEY=/etc/mariadb-backup/ssh_key
HOST=$(hostname -s)
START=$(date +%s)

DISCORD_WEBHOOK_URL="{{ discord }}"
SLACK_WEBHOOK_URL="{{ slack }}"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }

notify() {
    local emoji="$1" text="$2"
    local msg="${emoji} [${HOST}] ${text}"
    if [ -n "$DISCORD_WEBHOOK_URL" ]; then
        jq -n --arg m "$msg" '{username:"Backup",content:$m}' \
        | curl -sSL --max-time 30 -X POST -H "Content-Type: application/json" -d @- \
            "$DISCORD_WEBHOOK_URL" || true
    fi
    if [ -n "$SLACK_WEBHOOK_URL" ]; then
        jq -n --arg m "$msg" '{text:$m}' \
        | curl -sSL --max-time 30 -X POST -H "Content-Type: application/json" -d @- \
            "$SLACK_WEBHOOK_URL" || true
    fi
}

on_exit() {
    local code=$?
    if [ $code -ne 0 ]; then
        local elapsed=$(( $(date +%s) - START ))
        notify ":x:" "${MODE} backup FAILED after ${elapsed}s (exit ${code})"
    fi
}
trap on_exit EXIT

rsync_to_remote() {
    local src="$1" dst="$2"
    rsync -az --delete \
        -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no -o BatchMode=yes" \
        "$src" "$REMOTE_USER@$REMOTE_HOST:$REMOTE_PATH/$HOST/$dst"
}

run_full() {
    log "Starting full base backup"
    [ -d "${BASE_DIR}.prev" ] && rm -rf "${BASE_DIR}.prev"
    [ -d "$BASE_DIR" ] && mv "$BASE_DIR" "${BASE_DIR}.prev"
    mkdir -p "$BASE_DIR"

    mariabackup --backup \
        --target-dir="$BASE_DIR" \
        --user="$MYSQL_USER" \
        --password="$MYSQL_PASS"

    mariabackup --prepare --target-dir="$BASE_DIR"

    rm -rf "$INCR_BASE"
    mkdir -p "$INCR_BASE"

    log "Syncing full backup to remote"
    rsync_to_remote "$BASE_DIR/" "base/"

    local elapsed=$(( $(date +%s) - START ))
    local size; size=$(du -sh "$BASE_DIR" | cut -f1)
    log "Full backup complete — size: ${size}, duration: ${elapsed}s"
    notify ":white_check_mark:" "full backup complete — size: ${size}, duration: ${elapsed}s"
}

if [ "$MODE" = "full" ]; then
    run_full

elif [ "$MODE" = "incremental" ]; then
    NOW=$(date +%s)

    # If no base exists or it is 7+ days old (missed weekly run), create one first
    if [ ! -d "$BASE_DIR" ]; then
        log "No base backup found; running full backup first"
        run_full
        START=$(date +%s)
    else
        BASE_AGE=$(( (NOW - $(stat -c %Y "$BASE_DIR")) / 86400 ))
        if [ "$BASE_AGE" -ge 7 ]; then
            log "Base backup is ${BASE_AGE}d old (weekly run missed); running full backup first"
            run_full
            START=$(date +%s)
        fi
    fi

    log "Starting incremental backup"
    mkdir -p "$INCR_BASE"

    LAST_INCR=$(ls -dt "$INCR_BASE"/[0-9]* 2>/dev/null | head -1)
    BASEDIR="${LAST_INCR:-$BASE_DIR}"
    DATE=$(date +%Y%m%d-%H%M%S)
    INCR_DIR="$INCR_BASE/$DATE"
    mkdir -p "$INCR_DIR"

    mariabackup --backup \
        --incremental-basedir="$BASEDIR" \
        --target-dir="$INCR_DIR" \
        --user="$MYSQL_USER" \
        --password="$MYSQL_PASS"

    log "Syncing incremental backup to remote"
    rsync_to_remote "$INCR_DIR/" "incremental/$DATE/"

    elapsed=$(( $(date +%s) - START ))
    size=$(du -sh "$INCR_DIR" | cut -f1)
    log "Incremental backup complete — size: ${size}, duration: ${elapsed}s"
    notify ":white_check_mark:" "incremental backup complete — size: ${size}, duration: ${elapsed}s"

else
    echo "Usage: $0 [full|incremental]" >&2
    exit 1
fi
