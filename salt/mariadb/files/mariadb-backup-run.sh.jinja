#!/bin/bash
# Streams full or incremental mariabackup directly to the remote backup server via SSH.
# No backup data is written to local disk — only two small state files are kept:
#   /var/backups/mariadb/xtrabackup_checkpoints  (LSN for next incremental)
#   /var/backups/mariadb/last_full_backup         (epoch of last full)
#   /var/backups/mariadb/last_backup              (epoch of last backup of any kind)
# Usage: mariadb-backup-run.sh [full|incremental]
{%- set backup = salt['pillar.get']('mariadb:backup', {}) %}
{%- set dest = backup.get('destination', {}) %}
{%- set discord = salt['pillar.get']('notifications:discord_webhook_url', '') %}
{%- set slack = salt['pillar.get']('notifications:slack_webhook_url', '') %}
set -euo pipefail
ulimit -n 524288
MODE="${1:-incremental}"
STATE_DIR=/var/backups/mariadb

# Serialize backups. A busy DB's incremental can run for the better part of an
# hour; without a lock a manual rerun or an overrun into the next scheduled run
# would start a second mariabackup against the same state files and corrupt the
# LSN tracking. Non-blocking: if one is already running we just skip this run.
LOCK_FILE=/run/mariadb-backup.lock
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Another backup is already running; skipping"
    exit 0
fi
CHECKPOINTS="$STATE_DIR/xtrabackup_checkpoints"
LAST_FULL="$STATE_DIR/last_full_backup"
LAST_BACKUP="$STATE_DIR/last_backup"
MYSQL_USER="{{ backup.get('user', 'mariadb_backup') }}"
MYSQL_PASS="{{ backup.get('password', '') }}"
REMOTE_USER="{{ dest.get('user', '') }}"
REMOTE_HOST="{{ dest.get('host', '') }}"
REMOTE_PATH="{{ dest.get('path', '/backup/mariadb') }}"
SSH_KEY=/etc/mariadb-backup/ssh_key
HOST=$(hostname -s)
START=$(date +%s)

DISCORD_WEBHOOK_URL="{{ discord }}"
SLACK_WEBHOOK_URL="{{ slack }}"

SSH="ssh -i $SSH_KEY -o StrictHostKeyChecking=no -o BatchMode=yes $REMOTE_USER@$REMOTE_HOST"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }

notify() {
    local emoji="$1" text="$2"
    local msg="${emoji} [${HOST}] ${text}"
    if [ -n "$DISCORD_WEBHOOK_URL" ]; then
        jq -n --arg m "$msg" '{username:"Backup",content:$m}' \
        | curl -sSL --max-time 30 -X POST -H "Content-Type: application/json" -d @- \
            "$DISCORD_WEBHOOK_URL" || true
    fi
    if [ -n "$SLACK_WEBHOOK_URL" ]; then
        jq -n --arg m "$msg" '{text:$m}' \
        | curl -sSL --max-time 30 -X POST -H "Content-Type: application/json" -d @- \
            "$SLACK_WEBHOOK_URL" || true
    fi
}

on_exit() {
    local code=$?
    if [ $code -ne 0 ]; then
        local elapsed=$(( $(date +%s) - START ))
        notify ":x:" "${MODE} backup FAILED after ${elapsed}s (exit ${code})"
    fi
}
trap on_exit EXIT

remote_size() {
    # Best-effort; never let a transient du/ssh hiccup fail an otherwise-good
    # backup (the data is already safely on the remote by the time this runs).
    $SSH "du -sh '$1' 2>/dev/null" | cut -f1 || true
}

# Record the checkpoint LSN from the backup just streamed to the remote.
# mariabackup's --extra-lsndir is unreliable for streamed backups: the local
# copy is often missing or carries a stale to_lsn that never advances. That made
# most DBs fall back to a full every run, and on busy DBs made each incremental
# chain from an ever-older LSN until it ballooned and broke the SSH stream.
# The xtrabackup_checkpoints extracted on the remote always reflects this exact
# backup, so it is the source of truth. If we can't fetch it, drop the local
# checkpoints so the next run safely does a full rather than a bad incremental.
save_checkpoints() {
    local remote_dir="$1"
    if $SSH "cat '${remote_dir}/xtrabackup_checkpoints'" > "$CHECKPOINTS.tmp" \
        && grep -q '^to_lsn' "$CHECKPOINTS.tmp"; then
        mv "$CHECKPOINTS.tmp" "$CHECKPOINTS"
    else
        log "WARNING: could not fetch valid checkpoints from remote; next run will do a full"
        rm -f "$CHECKPOINTS" "$CHECKPOINTS.tmp"
    fi
}

run_full() {
    log "Starting streamed full backup"
    $SSH "rm -rf '$REMOTE_PATH/$HOST/base.prev' ; \
          [ -d '$REMOTE_PATH/$HOST/base' ] && mv '$REMOTE_PATH/$HOST/base' '$REMOTE_PATH/$HOST/base.prev' ; \
          mkdir -p '$REMOTE_PATH/$HOST/base'"

    mariabackup --backup --stream=xbstream \
        --open-files-limit=524288 \
        --user="$MYSQL_USER" --password="$MYSQL_PASS" \
    | $SSH "mbstream -x -C '$REMOTE_PATH/$HOST/base/'"

    save_checkpoints "$REMOTE_PATH/$HOST/base"

    local now; now=$(date +%s)
    echo "$now" > "$LAST_FULL"
    echo "$now" > "$LAST_BACKUP"

    local elapsed=$(( now - START ))
    local size; size=$(remote_size "$REMOTE_PATH/$HOST/base/")
    log "Full backup complete — size: ${size}, duration: ${elapsed}s"
    notify ":white_check_mark:" "full backup complete — size: ${size}, duration: ${elapsed}s"
}

run_incremental() {
    if [ ! -f "$CHECKPOINTS" ]; then
        log "No checkpoints file found; running full backup first"
        run_full
        return
    fi

    local full_age=$(( ($(date +%s) - $(cat "$LAST_FULL")) / 86400 ))
    if [ "$full_age" -ge 7 ]; then
        log "Full backup is ${full_age}d old (weekly run missed); running full backup first"
        run_full
        return
    fi

    local to_lsn; to_lsn=$(awk '/^to_lsn/{print $3}' "$CHECKPOINTS")
    if ! [[ "$to_lsn" =~ ^[0-9]+$ ]]; then
        log "Checkpoints file has no valid to_lsn ('${to_lsn}'); running full backup"
        rm -f "$CHECKPOINTS"
        run_full
        return
    fi
    local DATE; DATE=$(date +%Y%m%d-%H%M%S)

    log "Starting streamed incremental backup (from LSN ${to_lsn})"
    $SSH "mkdir -p '$REMOTE_PATH/$HOST/incremental/$DATE'"

    if ! { mariabackup --backup --stream=xbstream \
        --incremental-lsn="$to_lsn" \
        --open-files-limit=524288 \
        --user="$MYSQL_USER" --password="$MYSQL_PASS" \
    | $SSH "mbstream -x -C '$REMOTE_PATH/$HOST/incremental/$DATE/'"; }; then
        log "Incremental backup failed (LSN ${to_lsn} incompatible with current server state); falling back to full backup"
        rm -f "$CHECKPOINTS"
        $SSH "rm -rf '$REMOTE_PATH/$HOST/incremental/$DATE'"
        run_full
        return
    fi

    # Advance the checkpoint so the next incremental chains from this one.
    save_checkpoints "$REMOTE_PATH/$HOST/incremental/$DATE"

    local now; now=$(date +%s)
    echo "$now" > "$LAST_BACKUP"

    local elapsed=$(( now - START ))
    local size; size=$(remote_size "$REMOTE_PATH/$HOST/incremental/$DATE/")
    log "Incremental backup complete — size: ${size}, duration: ${elapsed}s"
    notify ":white_check_mark:" "incremental backup complete — size: ${size}, duration: ${elapsed}s"
}

case "$MODE" in
    full)        run_full ;;
    incremental) run_incremental ;;
    *)           echo "Usage: $0 [full|incremental]" >&2; exit 1 ;;
esac
