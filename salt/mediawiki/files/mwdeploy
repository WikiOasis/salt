# ---------------------------------------------------------------------------
# Prompter — TUI-safe blocking user prompts
# ---------------------------------------------------------------------------

class _PromptRequest:
    def __init__(self, question: str, opts: dict[str, str]):
        self.question = question
        self.opts     = opts
        self._event   = threading.Event()
        self._answer: str = ""

    def answer(self, key: str):
        self._answer = key.lower()
        self._event.set()

    def wait(self, timeout: float = 300.0) -> str:
        self._event.wait(timeout)
        return self._answer


class Prompter:
    def __init__(self):
        self._ask_lock   = threading.Lock()   # serialise: one prompt at a time
        self._state_lock = threading.Lock()   # protects _pending
        self._abort      = threading.Event()
        self._pending: _PromptRequest | None = None

    def ask(self, question: str,
            opts: dict[str, str] | None = None,
            default: str = "n") -> str:
        if self._abort.is_set():
            return default
        opts = opts or {"y": "Yes", "n": "No"}
        # _ask_lock serialises concurrent callers so they queue rather than
        # overwriting each other's _pending slot.
        with self._ask_lock:
            if self._abort.is_set():
                return default
            req = _PromptRequest(question, opts)
            with self._state_lock:
                self._pending = req
            ans = req.wait(timeout=300.0)
            with self._state_lock:
                self._pending = None
        return ans or default

    def pending(self) -> _PromptRequest | None:
        with self._state_lock:
            return self._pending

    def abort(self):
        self._abort.set()
        # Wake any blocked req.wait() immediately instead of waiting 300 s.
        with self._state_lock:
            if self._pending and not self._pending._event.is_set():
                self._pending._event.set()   # _answer stays "" → ask() returns default

    def is_aborted(self) -> bool:
        return self._abort.is_set()


# ---------------------------------------------------------------------------
# DeployState — thread-safe runtime state, persisted to disk
# ---------------------------------------------------------------------------

def _new_row() -> dict:
    return {
        "status":        S_PENDING,
        "log_lines":     [],
        "snapshot":      None,
        "started_at_ts": None,
        "finished_at_ts": None,
        "step":          "",
        "steps_done":    0,
        "steps_total":   0,
    }


class DeployState:
    MAX_LOG = 80

    def __init__(self, servers: list[str]):
        self._lock    = threading.Lock()
        self._started = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        self._servers: dict[str, dict] = {s: _new_row() for s in servers}
        self._done    = threading.Event()

    def update(self, server: str, *,
               status:      str | None = None,
               line:        str | None = None,
               snapshot:    str | None = None,
               step:        str | None = None,
               steps_done:  int | None = None,
               steps_total: int | None = None):
        ts = datetime.now(timezone.utc).strftime("%H:%M:%S")
        with self._lock:
            row = self._servers.setdefault(server, _new_row())
            if status is not None:
                if row["status"] != S_RUNNING and status == S_RUNNING:
                    row["started_at_ts"] = time.time()
                if status in _TERMINAL_ST \
                        and row.get("started_at_ts") \
                        and not row.get("finished_at_ts"):
                    row["finished_at_ts"] = time.time()
                row["status"] = status
            if line is not None:
                row["log_lines"].append(f"{ts}  {line}")
                row["log_lines"] = row["log_lines"][-self.MAX_LOG:]
            if snapshot    is not None: row["snapshot"]    = snapshot
            if step        is not None: row["step"]        = step
            if steps_done  is not None: row["steps_done"]  = steps_done
            if steps_total is not None: row["steps_total"] = steps_total
        self._save()

    def mark_done(self):
        self._done.set()

    def is_done(self) -> bool:
        return self._done.is_set()

    def snapshot(self) -> dict:
        now = time.time()
        with self._lock:
            servers = {}
            for k, v in self._servers.items():
                d          = dict(v)
                started_ts = v.get("started_at_ts")
                fin_ts     = v.get("finished_at_ts")
                if started_ts:
                    d["elapsed_s"] = (fin_ts if fin_ts else now) - started_ts
                else:
                    d["elapsed_s"] = 0.0
                servers[k] = d
            return {
                "started":  self._started,
                "finished": self._done.is_set(),
                "servers":  servers,
            }

    def server_snapshot_path(self, server: str) -> str | None:
        with self._lock:
            return self._servers.get(server, {}).get("snapshot")

    def _save(self):
        try:
            data = self.snapshot()
            tmp  = STATE_FILE + ".tmp"
            with open(tmp, "w") as f:
                json.dump(data, f, indent=2)
            os.replace(tmp, STATE_FILE)
        except OSError:
            pass

    @staticmethod
    def load_file() -> dict | None:
        try:
            with open(STATE_FILE) as f:
                return json.load(f)
        except (FileNotFoundError, json.JSONDecodeError, OSError):
            return None


# ---------------------------------------------------------------------------
# Logging + webhooks
# ---------------------------------------------------------------------------

class _WebhookHandler(logging.Handler):
    def __init__(self, discord: str = "", slack: str = ""):
        super().__init__()
        self._discord = discord
        self._slack   = slack

    def _post(self, url: str, payload: dict):
        data = json.dumps(payload).encode()
        req  = urllib.request.Request(
            url, data=data,
            headers={"Content-Type": "application/json"}, method="POST",
        )
        try:
            urllib.request.urlopen(req, timeout=5)
        except Exception:
            pass

    def emit(self, record):
        msg = self.format(record)
        if self._discord: self._post(self._discord, {"content": msg})
        if self._slack:   self._post(self._slack,   {"text":    msg})


def _setup_logging(cfg: dict, no_log: bool, suppress_stdout: bool = False) -> logging.Logger:
    log = logging.getLogger("mwdeploy")
    log.setLevel(logging.DEBUG)
    fmt = logging.Formatter(
        "%(asctime)s [%(levelname)s] %(message)s", datefmt="%Y-%m-%dT%H:%M:%SZ"
    )
    if not suppress_stdout:
        ch = logging.StreamHandler(sys.stdout)
        ch.setFormatter(fmt)
        log.addHandler(ch)
    if no_log:
        return log
    log_file = cfg.get("log_file", "/var/log/mwdeploy.log")
    try:
        fh = logging.FileHandler(log_file)
        fh.setFormatter(fmt)
        log.addHandler(fh)
    except OSError as e:
        log.warning("Cannot open log file %s: %s", log_file, e)
    webhooks = cfg.get("webhooks", {})
    discord  = webhooks.get("discord") or ""
    slack    = webhooks.get("slack")   or ""
    if discord or slack:
        wh = _WebhookHandler(discord, slack)
        wh.setLevel(logging.WARNING)
        wh.setFormatter(logging.Formatter("[mwdeploy] %(levelname)s: %(message)s"))
        log.addHandler(wh)
    return log


def _notify(log: logging.Logger, cfg: dict, no_log: bool, msg: str,
            level: int = logging.INFO):
    log.log(level, msg)
    if no_log:
        return
    webhooks = cfg.get("webhooks", {})
    discord  = webhooks.get("discord") or ""
    slack    = webhooks.get("slack")   or ""
    if not (discord or slack):
        return
    h = _WebhookHandler(discord, slack)
    payload = f"[mwdeploy] {msg}"
    if discord: h._post(discord, {"content": payload})
    if slack:   h._post(slack,   {"text":    payload})


# ---------------------------------------------------------------------------
# Shell helpers
# ---------------------------------------------------------------------------

def _run(cmd: list, **kwargs) -> subprocess.CompletedProcess:
    logging.getLogger("mwdeploy").debug("$ %s", " ".join(str(c) for c in cmd))
    return subprocess.run(cmd, capture_output=True, text=True, **kwargs)


def _run_check(cmd: list, error_prefix: str = "Command failed", **kwargs):
    r = _run(cmd, **kwargs)
    if r.returncode != 0:
        raise RuntimeError(
            f"{error_prefix}\n"
            f"stdout: {r.stdout.strip()}\nstderr: {r.stderr.strip()}"
        )
    return r


# ---------------------------------------------------------------------------
# Git
# ---------------------------------------------------------------------------

def git_pull(path: str, log: logging.Logger) -> subprocess.CompletedProcess:
    log.info("git pull  %s", path)
    # Fix .git/ ownership so www-data can write FETCH_HEAD, index, etc.
    # (Previous root-run git ops leave root-owned files behind.)
    subprocess.run(
        ["chown", "-R", "www-data:www-data", os.path.join(path, ".git")],
        capture_output=True,
    )
    git = ["sudo", "-u", "www-data", "git", "-c", "safe.directory=*", "-C", path]
    # Fetch first so FETCH_HEAD is set regardless of local state.
    _run_check(git + ["fetch", "--quiet", "origin"],
               error_prefix=f"git fetch failed in {path}")
    # Hard-reset to the fetched ref — this discards any local modifications
    # (config drift, leftover edits) that would block a normal merge.
    r = _run_check(git + ["reset", "--hard", "FETCH_HEAD"],
                   error_prefix=f"git reset failed in {path}")
    out = (r.stdout or r.stderr or "").strip()
    if out:
        log.debug("git: %s", out)
    return r


# ---------------------------------------------------------------------------
# Localisation cache rebuild
# ---------------------------------------------------------------------------

def l10n_rebuild(host: str, cfg: dict, log: logging.Logger):
    prod_path   = cfg["prod_path"]
    deploy_user = cfg["deploy_user"]
    script      = f"{prod_path}/scripts/mwscript.php"
    cmd         = f"sudo -u www-data {script} rebuildLocalisationCache --wiki testwiki"

    log.info("L10n cache rebuild on %s", host)
    if host == STAGING_KEY:
        r = _run(["bash", "-c", cmd])
    else:
        r = _run(["ssh"] + _SSH_OPTS + [f"{deploy_user}@{host}", cmd])

    if r.returncode != 0:
        raise RuntimeError(
            f"L10n rebuild failed on {host}\n"
            f"stdout: {r.stdout.strip()}\nstderr: {r.stderr.strip()}"
        )
    log.info("L10n rebuild complete on %s", host)


# ---------------------------------------------------------------------------
# Patch application
# ---------------------------------------------------------------------------

def apply_patch(patch_file: str, target_dir: str, log: logging.Logger):
    """Apply patch_file (absolute path) into target_dir using sudo -u www-data patch."""
    log.info("Applying patch %s → %s", patch_file, target_dir)
    r = _run(["sudo", "-u", "www-data", "patch", "-p1", "--batch",
              "-d", target_dir, "--input", patch_file])
    if r.returncode != 0:
        raise RuntimeError(
            f"patch failed\nstdout: {r.stdout.strip()}\nstderr: {r.stderr.strip()}"
        )
    log.info("Patch applied: %s", patch_file)


# ---------------------------------------------------------------------------
# Canary check
# ---------------------------------------------------------------------------

def canary_check(host: str, vhost: str, log: logging.Logger,
                 deploy_user: str = "mwdeploy",
                 force: bool = False, retries: int = 3,
                 prompter: Prompter | None = None) -> bool:
    curl_cmd = (
        f'code=$(curl -sS --max-time 15 --location'
        f' -H "Host: {vhost}"'
        f' -o /tmp/mwdeploy-canary'
        f' -w "%{{http_code}}"'
        f' "http://127.0.0.1/wiki/Main_Page" 2>&1);'
        f' echo "HTTP_CODE=$code";'
        f' grep -qi mediawiki /tmp/mwdeploy-canary'
        f' && echo "HAS_MW=1" || echo "HAS_MW=0";'
        f' rm -f /tmp/mwdeploy-canary'
    )
    log.info("Canary  %s  (Host: %s)", host, vhost)
    code = "???"
    for attempt in range(1, retries + 1):
        try:
            if host == STAGING_KEY:
                r = _run(["bash", "-c", curl_cmd])
            else:
                r = _run(["ssh"] + _SSH_OPTS + [f"{deploy_user}@{host}", curl_cmd])
            output = r.stdout
            code = next(
                (ln.replace("HTTP_CODE=", "").strip()
                 for ln in output.splitlines() if ln.startswith("HTTP_CODE=")),
                "???",
            )
            has_mw = any(
                ln.strip() == "HAS_MW=1"
                for ln in output.splitlines() if ln.startswith("HAS_MW=")
            )
            if code == "200" and has_mw:
                log.info("Canary OK  %s  (HTTP 200)", host)
                return True
            reason = f"HTTP {code}" if code != "200" else "no MediaWiki content"
            log.warning("Canary attempt %d/%d failed on %s: %s",
                        attempt, retries, host, reason)
        except Exception as e:
            log.warning("Canary attempt %d/%d error on %s: %s",
                        attempt, retries, host, e)
        if attempt < retries:
            time.sleep(3)

    if force:
        log.warning("Canary failed on %s — --force set, continuing", host)
        return True

    short = _shorten(host)
    if prompter:
        if prompter.is_aborted():
            return False
        ans = prompter.ask(
            f"Canary failed on {short} (HTTP {code}). Continue?",
            {"y": "Yes, continue", "n": "Stop here"},
        )
        if ans != "y":
            prompter.abort()
        return ans == "y"
    else:
        ans = input(f"\nCanary failed on {host}. Continue? [y/N] ").strip().lower()
        return ans == "y"


# ---------------------------------------------------------------------------
# HAProxy
# ---------------------------------------------------------------------------

def _haproxy_cmd(proxy: str, deploy_user: str, socket: str,
                 command: str, log: logging.Logger):
    remote = f"printf '{command}\\n' | socat stdio {socket}"
    r = _run(["ssh"] + _SSH_OPTS + [f"{deploy_user}@{proxy}", remote])
    if r.returncode != 0:
        raise RuntimeError(f"HAProxy cmd on {proxy} failed: {r.stderr.strip()}")
    return r.stdout


def _depool(proxy, deploy_user, socket, backend, server, log):
    log.info("Depooling  %s/%s  via %s", backend, server, proxy)
    _haproxy_cmd(proxy, deploy_user, socket,
                 f"disable server {backend}/{server}", log)


def _repool(proxy, deploy_user, socket, backend, server, log):
    log.info("Repooling  %s/%s  via %s", backend, server, proxy)
    _haproxy_cmd(proxy, deploy_user, socket,
                 f"enable server {backend}/{server}", log)


def _depool_all(cfg: dict, server: str, log: logging.Logger):
    for p in cfg.get("proxy_servers", []):
        try:
            _depool(p, cfg["deploy_user"], cfg["haproxy_socket"],
                    cfg["haproxy_backend"], server, log)
        except RuntimeError as e:
            log.error("Depool %s from %s: %s", server, p, e)


def _repool_all(cfg: dict, server: str, log: logging.Logger):
    for p in cfg.get("proxy_servers", []):
        try:
            _repool(p, cfg["deploy_user"], cfg["haproxy_socket"],
                    cfg["haproxy_backend"], server, log)
        except RuntimeError as e:
            log.error("Repool %s into %s: %s", server, p, e)


# ---------------------------------------------------------------------------
# Rsync
# ---------------------------------------------------------------------------

def _rsync_base(extra_excludes: list[str]) -> list[str]:
    cmd = ["rsync", "-az", "--delete"]
    for ex in ["cache/"] + extra_excludes:
        cmd += ["--exclude", ex]
    return cmd


def rsync_local(src: str, dst: str, log: logging.Logger, provision: bool = False):
    log.info("Local rsync  %s → %s", src, dst)
    excludes = [] if provision else ["cw_cache/"]
    _run_check(
        _rsync_base(excludes) + [src.rstrip("/") + "/", dst.rstrip("/") + "/"],
        error_prefix="Local rsync failed",
    )


def rsync_remote(src: str, host: str, dst: str, deploy_user: str,
                 log: logging.Logger, provision: bool = False):
    log.info("Remote rsync  %s → %s:%s", src, host, dst)
    excludes = [] if provision else ["cw_cache/"]
    ssh_cmd  = "ssh " + " ".join(_SSH_OPTS)
    _run_check(
        _rsync_base(excludes) + [
            "--rsync-path=sudo rsync",
            "--chown=www-data:mediawiki-admins",
            "-e", ssh_cmd,
            src.rstrip("/") + "/",
            f"{deploy_user}@{host}:{dst.rstrip('/')}/",
        ],
        error_prefix=f"Remote rsync to {host} failed",
    )


def rsync_local_path(src: str, dst: str, log: logging.Logger):
    """Rsync an exact subdirectory without staging-level cache excludes."""
    log.info("Local rsync  %s → %s", src, dst)
    _run_check(
        ["rsync", "-a", "--delete",
         src.rstrip("/") + "/", dst.rstrip("/") + "/"],
        error_prefix=f"Local rsync failed: {src}",
    )


def rsync_remote_path(src: str, host: str, dst: str, deploy_user: str,
                      log: logging.Logger):
    """Rsync an exact subdirectory to a remote host."""
    log.info("Remote rsync  %s → %s:%s", src, host, dst)
    ssh_cmd = "ssh " + " ".join(_SSH_OPTS)
    _run_check(
        ["rsync", "-az", "--delete",
         "--rsync-path=sudo rsync",
         "--chown=www-data:mediawiki-admins",
         "-e", ssh_cmd,
         src.rstrip("/") + "/",
         f"{deploy_user}@{host}:{dst.rstrip('/')}/"],
        error_prefix=f"Remote rsync to {host}:{dst} failed",
    )


def _build_rsync_targets(args, staging_path: str, prod_path: str,
                         versions: list[str], extensions: list[str],
                         skins: list[str]) -> list[tuple[str, str]]:
    """
    Return (src, dst) path pairs for the local staging→prod rsync and the
    remote rsyncs.  In git-pull mode only the affected subdirectories are
    synced; --rsync always syncs the full tree.
    """
    if args.rsync or args.core:
        return [(staging_path, prod_path)]

    targets: list[tuple[str, str]] = []

    if args.config:
        targets.append((
            os.path.join(staging_path, "config"),
            os.path.join(prod_path,    "config"),
        ))

    for ver in versions:
        vp_src = os.path.join(staging_path, "versions", ver)
        vp_dst = os.path.join(prod_path,    "versions", ver)
        if args.mediawiki:
            # whole version dir (includes extensions/ and skins/)
            targets.append((vp_src, vp_dst))
        else:
            for ext in extensions:
                targets.append((
                    os.path.join(vp_src, "extensions", ext),
                    os.path.join(vp_dst, "extensions", ext),
                ))
            for skin in skins:
                targets.append((
                    os.path.join(vp_src, "skins", skin),
                    os.path.join(vp_dst, "skins", skin),
                ))

    # Fall back to full sync if no specific targets were identified
    return targets or [(staging_path, prod_path)]



# ---------------------------------------------------------------------------
# Version / server resolution
# ---------------------------------------------------------------------------

def resolve_versions(arg: str, staging_path: str) -> list[str]:
    if arg == "all":
        vd = Path(staging_path) / "versions"
        if not vd.is_dir():
            sys.exit(f"versions/ not found under {staging_path}")
        return sorted(d.name for d in vd.iterdir() if d.is_dir())
    return [arg]


def resolve_servers(arg: str | None, all_servers: list) -> list[str]:
    if arg is None or arg == "all":
        return list(all_servers)
    return [s.strip() for s in arg.split(",") if s.strip()]


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _shorten(name: str) -> str:
    return name.split(".")[0]


def _fmt_elapsed(seconds: float) -> str:
    s = int(seconds)
    if s < 60:
        return f"{s}s"
    m, s = divmod(s, 60)
    return f"{m}m {s}s"


# ---------------------------------------------------------------------------
# Deploy one server
# ---------------------------------------------------------------------------

def _deploy_server(server: str, cfg: dict, args,
                   log: logging.Logger, state: DeployState,
                   prompter: Prompter,
                   rsync_targets: list[tuple[str, str]] | None = None) -> bool:

    if prompter.is_aborted():
        state.update(server, status=S_SKIPPED,
                     line="Skipped — deploy aborted by earlier failure")
        return True

    deploy_user  = cfg["deploy_user"]
    staging_path = cfg["staging_path"]
    prod_path    = cfg["prod_path"]
    canary_vhost = cfg["canary_vhost"]

    step_names: list[str] = []
    if args.rollout:
        step_names += ["depool"]
    step_names += ["rsync"]
    if args.l10n:
        step_names += ["l10n"]
    step_names += ["canary"]
    if args.rollout:
        step_names += ["repool"]
    steps_total = len(step_names)
    steps_done  = 0

    state.update(server, status=S_RUNNING, line="Starting deploy",
                 steps_total=steps_total, steps_done=0, step="")

    if args.rollout:
        state.update(server, steps_done=steps_done, step="depool",
                     line="Depooling from HAProxy…")
        _depool_all(cfg, server, log)
        state.update(server, line="Depooled from HAProxy")
        steps_done += 1

    state.update(server, steps_done=steps_done, step="rsync",
                 line="Syncing files…")
    try:
        is_full_sync = (
            args.provision
            or not rsync_targets
            or rsync_targets == [(cfg["staging_path"], prod_path)]
        )
        if is_full_sync:
            src = prod_path if args.provision else cfg["staging_path"]
            rsync_remote(src, server, prod_path, deploy_user, log,
                         provision=args.provision)
        else:
            n = len(rsync_targets)
            if n == 1:
                t_src, t_dst = rsync_targets[0]
                lbl = os.path.relpath(t_src, cfg["staging_path"])
                state.update(server, line=f"rsync {lbl}…")
                rsync_remote_path(t_src, server, t_dst, deploy_user, log)
            else:
                state.update(server, line=f"rsync {n} paths in parallel…")
                with concurrent.futures.ThreadPoolExecutor(max_workers=min(4, n)) as pool:
                    futs = {
                        pool.submit(rsync_remote_path, t_src, server, t_dst, deploy_user, log): (i, t_src)
                        for i, (t_src, t_dst) in enumerate(rsync_targets, 1)
                    }
                    for fut in concurrent.futures.as_completed(futs):
                        i, t_src = futs[fut]
                        lbl = os.path.relpath(t_src, cfg["staging_path"])
                        fut.result()  # propagates RuntimeError on failure
                        state.update(server, line=f"rsync {lbl} done  ({i}/{n})")
        steps_done += 1
        state.update(server, steps_done=steps_done, line="Rsync complete")
    except RuntimeError as e:
        log.error("rsync failed for %s: %s", server, e)
        state.update(server, status=S_FAILED, line=f"Rsync FAILED: {e}")
        if args.rollout:
            _repool_all(cfg, server, log)
            state.update(server, line="Repooled after rsync failure")
        if not args.force:
            prompter.abort()
        return False

    if args.l10n:
        state.update(server, steps_done=steps_done, step="l10n",
                     line="Rebuilding localisation cache…")
        try:
            l10n_rebuild(server, cfg, log)
            steps_done += 1
            state.update(server, steps_done=steps_done, line="L10n cache rebuilt")
        except RuntimeError as e:
            log.error("L10n rebuild failed for %s: %s", server, e)
            state.update(server, status=S_FAILED, line=f"L10n rebuild FAILED: {e}")
            if args.rollout:
                _repool_all(cfg, server, log)
                state.update(server, line="Repooled after l10n failure")
            if not args.force:
                prompter.abort()
            return False

    state.update(server, steps_done=steps_done, step="canary",
                 line="Running canary check…")
    if not canary_check(server, canary_vhost, log, deploy_user=deploy_user,
                        force=args.force, prompter=prompter):
        log.error("Canary failed on %s", server)
        state.update(server, status=S_FAILED, line="Canary check FAILED")

        if args.rollout:
            _repool_all(cfg, server, log)
            state.update(server, line="Repooled")

        return False

    steps_done += 1
    state.update(server, steps_done=steps_done, line="Canary OK")

    if args.rollout:
        state.update(server, steps_done=steps_done, step="repool",
                     line="Repooling into HAProxy…")
        _repool_all(cfg, server, log)
        steps_done += 1
        state.update(server, steps_done=steps_done, line="Repooled into HAProxy")

    state.update(server, status=S_DONE, step="", steps_done=steps_total,
                 line="Deploy complete")
    return True


# ---------------------------------------------------------------------------
# Dashboard TUI
# ---------------------------------------------------------------------------

_C_NAME    = 1
_C_DONE    = 2
_C_FAIL    = 3
_C_RUNNING = 4
_C_PENDING = 5
_C_LOG     = 6
_C_BAR     = 7
_C_SEL     = 8
_C_HEAD    = 9
_C_DIM     = 10


class Dashboard:
    REFRESH_MS   = 250
    MAX_LOG_MAIN = 6

    def __init__(self, state: DeployState | None,
                 prompter: Prompter | None,
                 cfg: dict):
        self._state    = state
        self._prompter = prompter
        self._cfg      = cfg
        self._selected = 0
        self._detail:  str | None = None
        self._detail_scroll = 0
        self._confirm_haproxy: str | None = None   # server awaiting Ctrl+R depool/repool

    # ------------------------------------------------------------------
    # Entry point
    # ------------------------------------------------------------------

    def run(self):
        curses.wrapper(self._main)

    def _main(self, scr):
        self._init_colors()
        curses.curs_set(0)
        scr.nodelay(True)
        scr.timeout(self.REFRESH_MS)

        while True:
            data       = self._data()
            mw_servers = [s for s in data.get("servers", {}) if s != STAGING_KEY]

            try:
                if self._detail:
                    sd = data["servers"].get(self._detail, {})
                    self._draw_detail(scr, self._detail, sd)
                else:
                    self._draw_main(scr, data, mw_servers)
                    if self._confirm_haproxy:
                        self._draw_haproxy_confirm(scr, self._confirm_haproxy)
                    else:
                        req = self._prompter.pending() if self._prompter else None
                        if req:
                            self._draw_prompt(scr, req)
            except Exception:
                pass   # never let a draw error kill the TUI

            try:
                key = scr.getch()
            except curses.error:
                key = -1

            if key == -1:
                continue

            # Priority: haproxy confirm > deploy prompt > detail > main
            if self._confirm_haproxy:
                if not self._handle_haproxy_key(key):
                    return
                continue

            req = self._prompter.pending() if self._prompter else None
            if req:
                if not self._handle_prompt_key(key, req):
                    return
                continue

            if self._detail:
                if not self._handle_detail_key(key, data):
                    return
                continue

            if not self._handle_main_key(key, mw_servers, data):
                return

    # ------------------------------------------------------------------
    # Data source
    # ------------------------------------------------------------------

    def _data(self) -> dict:
        if self._state:
            return self._state.snapshot()
        d = DeployState.load_file()
        return d if d else {"started": "", "finished": False, "servers": {}}

    # ------------------------------------------------------------------
    # Colors
    # ------------------------------------------------------------------

    def _init_colors(self):
        curses.start_color()
        curses.use_default_colors()
        curses.init_pair(_C_NAME,    curses.COLOR_GREEN,  -1)
        curses.init_pair(_C_DONE,    curses.COLOR_GREEN,  -1)
        curses.init_pair(_C_FAIL,    curses.COLOR_RED,    -1)
        curses.init_pair(_C_RUNNING, curses.COLOR_YELLOW, -1)
        curses.init_pair(_C_PENDING, curses.COLOR_WHITE,  -1)
        curses.init_pair(_C_LOG,     curses.COLOR_CYAN,   -1)
        curses.init_pair(_C_BAR,     curses.COLOR_BLACK,  curses.COLOR_GREEN)
        curses.init_pair(_C_SEL,     curses.COLOR_BLACK,  curses.COLOR_GREEN)
        curses.init_pair(_C_HEAD,    curses.COLOR_GREEN,  -1)
        curses.init_pair(_C_DIM,     curses.COLOR_WHITE,  -1)

    def _status_attr(self, status: str) -> int:
        return {
            S_DONE:     curses.color_pair(_C_DONE)    | curses.A_BOLD,
            S_FAILED:   curses.color_pair(_C_FAIL)    | curses.A_BOLD,
            S_RUNNING:  curses.color_pair(_C_RUNNING) | curses.A_BOLD,
            S_ROLLBACK: curses.color_pair(_C_RUNNING),
            S_SKIPPED:  curses.color_pair(_C_PENDING),
        }.get(status, curses.color_pair(_C_PENDING))

    # ------------------------------------------------------------------
    # Progress bar
    # ------------------------------------------------------------------

    def _draw_bar_progress(self, scr, row: int, x: int, avail: int,
                           done: int, total: int, step: str, attr: int):
        if total <= 0 or avail < 12:
            return
        bar_w  = min(24, avail - 14)
        filled = int(bar_w * done / total)
        bar    = "█" * filled + "░" * (bar_w - filled)
        pct    = int(100 * done / total)
        label  = f"[{bar}] {pct:3d}%  {step}"
        self._put(scr, row, x, label[:avail], attr)

    # ------------------------------------------------------------------
    # Main view
    # ------------------------------------------------------------------

    def _draw_main(self, scr, data: dict, mw_servers: list):
        h, w = scr.getmaxyx()
        scr.erase()

        srv  = data.get("servers", {})
        done = data.get("finished", False)

        staging    = srv.get(STAGING_KEY, {})
        staging_st = staging.get("status", S_PENDING)
        staging_done = staging_st in _TERMINAL_ST or STAGING_KEY not in srv

        mw_statuses = [srv.get(s, {}).get("status", S_PENDING) for s in mw_servers]
        all_mw_done = (
            all(st in _TERMINAL_ST for st in mw_statuses) if mw_servers else True
        )

        # ── Header ────────────────────────────────────────────────────
        if done or (all_mw_done and mw_servers):
            n_fail_mw   = sum(1 for st in mw_statuses if st == S_FAILED)
            prep_failed = staging_st == S_FAILED
            if prep_failed:
                title      = "mwdeploy — preparation failed"
                title_attr = curses.color_pair(_C_FAIL) | curses.A_BOLD
            elif n_fail_mw:
                title      = f"mwdeploy — {n_fail_mw} failure(s)"
                title_attr = curses.color_pair(_C_FAIL) | curses.A_BOLD
            else:
                title      = "mwdeploy — complete"
                title_attr = curses.color_pair(_C_DONE) | curses.A_BOLD
        else:
            title      = "mwdeploy"
            title_attr = curses.color_pair(_C_NAME) | curses.A_BOLD

        started = data.get("started", "")
        self._put(scr, 0, 2, title, title_attr)
        if started and w - len(started) - 4 > len(title) + 4:
            self._put(scr, 0, w - len(started) - 2, started,
                      curses.color_pair(_C_DIM))
        self._put(scr, 1, 0, "─" * (w - 1), curses.color_pair(_C_DIM))
        row = 2

        # ── Section 1: Preparation ────────────────────────────────────
        if STAGING_KEY in srv:
            elapsed = staging.get("elapsed_s", 0.0)
            step    = staging.get("step", "")
            s_done  = staging.get("steps_done", 0)
            s_total = staging.get("steps_total", 0)

            if not staging_done:
                elapsed_str = f"  [{_fmt_elapsed(elapsed)}]" if elapsed > 0 else ""
                self._put(scr, row, 2,
                          f"Preparation  ⟳{elapsed_str}",
                          curses.color_pair(_C_RUNNING) | curses.A_BOLD)
                row += 1
                if s_total > 0 and row < h - 2:
                    self._draw_bar_progress(scr, row, 4, w - 5,
                                            s_done, s_total, step,
                                            curses.color_pair(_C_RUNNING))
                    row += 1
                for ln in staging.get("log_lines", [])[-5:]:
                    if row >= h - 2:
                        break
                    self._put(scr, row, 6, ln[:w - 7], curses.color_pair(_C_LOG))
                    row += 1
                row += 1
            else:
                icon  = "✓" if staging_st == S_DONE else "✗"
                attr  = (curses.color_pair(_C_DONE) if staging_st == S_DONE
                         else curses.color_pair(_C_FAIL)) | curses.A_BOLD
                el    = f"  [{_fmt_elapsed(elapsed)}]" if elapsed > 0 else ""
                self._put(scr, row, 2,
                          f"Preparation  {icon} {staging_st}{el}", attr)
                row += 1
                lines = staging.get("log_lines", [])
                if lines and row < h - 2:
                    self._put(scr, row, 6, lines[-1][:w - 7],
                              curses.color_pair(_C_LOG))
                    row += 1
                row += 1

        # ── Section 2: Server deployment ──────────────────────────────
        if mw_servers and staging_done:
            n_done  = sum(1 for st in mw_statuses if st == S_DONE)
            n_total = len(mw_servers)
            sect    = "Servers" if all_mw_done else f"Deploying  ({n_done}/{n_total} done)"
            self._put(scr, row, 2, sect,
                      curses.color_pair(_C_HEAD) | curses.A_BOLD)
            self._put(scr, row + 1, 0, "─" * (w - 1), curses.color_pair(_C_DIM))
            row += 2

            for idx, name in enumerate(mw_servers):
                if row >= h - 4:
                    break
                sd      = srv.get(name, {})
                status  = sd.get("status", S_PENDING)
                icon    = _STATUS_ICON.get(status, status)
                short   = _shorten(name)
                sel     = (idx == self._selected)
                elapsed = sd.get("elapsed_s", 0.0)
                step    = sd.get("step", "")
                s_done  = sd.get("steps_done", 0)
                s_total = sd.get("steps_total", 0)
                el_str  = f"  [{_fmt_elapsed(elapsed)}]" if elapsed > 0 else ""

                # Server name + status + elapsed
                if sel:
                    self._put(scr, row, 0, " " * w, curses.color_pair(_C_SEL))
                    self._put(scr, row, 2,
                              f"{short:<24}{icon}{el_str}",
                              curses.color_pair(_C_SEL) | curses.A_BOLD)
                else:
                    self._put(scr, row, 2, f"{short:<24}",
                              curses.color_pair(_C_NAME) | curses.A_BOLD)
                    self._put(scr, row, 26, f"{icon}{el_str}",
                              self._status_attr(status))
                row += 1

                if status == S_PENDING:
                    continue

                # Progress bar for running servers
                if status == S_RUNNING and s_total > 0 and row < h - 3:
                    self._draw_bar_progress(scr, row, 6, w - 7,
                                            s_done, s_total, step,
                                            curses.color_pair(_C_RUNNING))
                    row += 1

                # Log lines — more when running, fewer when settled
                max_lines = self.MAX_LOG_MAIN if status == S_RUNNING else 3
                for ln in sd.get("log_lines", [])[-max_lines:]:
                    if row >= h - 3:
                        break
                    self._put(scr, row, 6, ln[:w - 7], curses.color_pair(_C_LOG))
                    row += 1

                if row < h - 3:
                    row += 1   # blank line between servers

        # ── Section 3: Summary ────────────────────────────────────────
        if (done or all_mw_done) and mw_servers \
                and staging_st != S_FAILED and row < h - 2:
            self._put(scr, row, 0, "─" * (w - 1), curses.color_pair(_C_DIM))
            row += 1
            if row < h - 2:
                n_done = sum(1 for st in mw_statuses if st == S_DONE)
                n_fail = sum(1 for st in mw_statuses if st == S_FAILED)
                n_skip = sum(1 for st in mw_statuses
                             if st in (S_SKIPPED, S_ROLLBACK))
                summary = (f"  ✓ {n_done} succeeded   "
                           f"✗ {n_fail} failed   "
                           f"– {n_skip} skipped/rolled back")
                attr = (curses.color_pair(_C_FAIL) if n_fail
                        else curses.color_pair(_C_DONE)) | curses.A_BOLD
                self._put(scr, row, 0, summary[:w], attr)
                row += 1

        # ── Section 4: Issues ─────────────────────────────────────────
        failed = [s for s in mw_servers
                  if srv.get(s, {}).get("status") == S_FAILED]
        if failed and row < h - 2:
            row += 1
            self._put(scr, row, 2, "Issues",
                      curses.color_pair(_C_FAIL) | curses.A_BOLD)
            row += 1
            for name in failed:
                if row >= h - 2:
                    break
                sd   = srv.get(name, {})
                last = (sd.get("log_lines") or ["unknown error"])[-1]
                self._put(scr, row, 4,
                          f"✗ {_shorten(name)}: {last}"[:w - 5],
                          curses.color_pair(_C_FAIL))
                row += 1

        self._draw_status_bar(scr,
            "  [↑↓] select   [Ctrl+O] detail logs   "
            "[Ctrl+R] depool/repool   [Ctrl+X] exit")
        scr.refresh()

    # ------------------------------------------------------------------
    # Prompt overlay
    # ------------------------------------------------------------------

    def _draw_prompt(self, scr, req: _PromptRequest):
        h, w = scr.getmaxyx()
        lines = ["", f"  {req.question}", ""]
        for key, label in req.opts.items():
            lines.append(f"  [{key.upper()}]  {label}")
        lines.append("")
        bw = min(w - 4, max(len(l) for l in lines) + 6)
        bh = len(lines) + 2
        y0 = max(1, h - bh - 3)
        x0 = max(0, (w - bw) // 2)
        for i, line in enumerate(lines):
            self._put(scr, y0 + i, x0,
                      line.ljust(bw)[:bw],
                      curses.color_pair(_C_BAR) | curses.A_BOLD)
        scr.refresh()

    # ------------------------------------------------------------------
    # Detail view (Ctrl+O)
    # ------------------------------------------------------------------

    def _draw_detail(self, scr, name: str, sdata: dict):
        h, w = scr.getmaxyx()
        scr.erase()

        status  = sdata.get("status", S_PENDING)
        icon    = _STATUS_ICON.get(status, status)
        elapsed = sdata.get("elapsed_s", 0.0)
        el_str  = f"  [{_fmt_elapsed(elapsed)}]" if elapsed > 0 else ""
        self._put(scr, 0, 2, f"{_shorten(name)}   {icon}{el_str}",
                  curses.color_pair(_C_NAME) | curses.A_BOLD)

        s_done  = sdata.get("steps_done", 0)
        s_total = sdata.get("steps_total", 0)
        step    = sdata.get("step", "")
        if s_total > 0:
            self._draw_bar_progress(scr, 1, 2, w - 3,
                                    s_done, s_total, step,
                                    curses.color_pair(_C_RUNNING))

        self._put(scr, 2, 0, "─" * (w - 1), curses.color_pair(_C_DIM))

        lines   = sdata.get("log_lines", [])
        visible = lines[self._detail_scroll: self._detail_scroll + h - 5]
        for i, ln in enumerate(visible):
            self._put(scr, 3 + i, 2, ln[:w - 3], curses.color_pair(_C_LOG))

        if not lines:
            self._put(scr, 4, 4, "(no log lines yet)", curses.color_pair(_C_PENDING))

        self._draw_status_bar(scr,
            "  [↑↓] scroll   [Q / Esc] back   [Ctrl+X] exit")
        scr.refresh()

    # ------------------------------------------------------------------
    # Status bar
    # ------------------------------------------------------------------

    def _draw_status_bar(self, scr, text: str):
        h, w = scr.getmaxyx()
        self._put(scr, h - 1, 0, text.ljust(w)[:w], curses.color_pair(_C_BAR))

    # ------------------------------------------------------------------
    # Safe addstr
    # ------------------------------------------------------------------

    @staticmethod
    def _put(scr, y: int, x: int, text: str, attr: int = 0):
        h, w = scr.getmaxyx()
        if y < 0 or y >= h or x < 0 or x >= w or not text:
            return
        try:
            scr.addstr(y, x, text[:max(0, w - x)], attr)
        except curses.error:
            pass

    # ------------------------------------------------------------------
    # Key handlers
    # ------------------------------------------------------------------

    def _draw_haproxy_confirm(self, scr, name: str):
        h, w = scr.getmaxyx()
        short = _shorten(name)
        lines = [
            "",
            f"  HAProxy pool action for {short}:",
            "",
            "  [D]  Depool (disable server)",
            "  [R]  Repool (enable server)",
            "  [N]  Cancel",
            "",
        ]
        bw = min(w - 4, max(len(l) for l in lines) + 6)
        y0 = max(1, h - len(lines) - 4)
        x0 = max(0, (w - bw) // 2)
        for i, line in enumerate(lines):
            self._put(scr, y0 + i, x0,
                      line.ljust(bw)[:bw],
                      curses.color_pair(_C_BAR) | curses.A_BOLD)
        scr.refresh()

    def _handle_haproxy_key(self, key: int) -> bool:
        name = self._confirm_haproxy
        if key in (ord("d"), ord("D")):
            self._confirm_haproxy = None
            log = logging.getLogger("mwdeploy")

            def _bg():
                _depool_all(self._cfg, name, log)
                if self._state:
                    self._state.update(name, line="Depooled from HAProxy (manual)")

            threading.Thread(target=_bg, daemon=True).start()
        elif key in (ord("r"), ord("R")):
            self._confirm_haproxy = None
            log = logging.getLogger("mwdeploy")

            def _bg():
                _repool_all(self._cfg, name, log)
                if self._state:
                    self._state.update(name, line="Repooled into HAProxy (manual)")

            threading.Thread(target=_bg, daemon=True).start()
        elif key in (ord("n"), ord("N"), 27):   # N or Esc → cancel
            self._confirm_haproxy = None
        elif key in (24, 3):                    # Ctrl+X / Ctrl+C → exit
            self._confirm_haproxy = None
            return False
        return True

    def _handle_main_key(self, key: int, mw_servers: list, data: dict) -> bool:
        n = len(mw_servers)
        if key == curses.KEY_UP:
            self._selected = max(0, self._selected - 1)
        elif key == curses.KEY_DOWN:
            self._selected = min(max(0, n - 1), self._selected + 1)
        elif key == 15:  # Ctrl+O
            if mw_servers:
                self._detail = mw_servers[min(self._selected, n - 1)]
                self._detail_scroll = 0
        elif key == 18:  # Ctrl+R — depool/repool menu
            if mw_servers and n > 0:
                name = mw_servers[min(self._selected, n - 1)]
                self._confirm_haproxy = name
        elif key in (24, 3, 27):  # Ctrl+X, Ctrl+C, Esc
            return False
        return True

    def _handle_detail_key(self, key: int, data: dict) -> bool:
        if key in (ord("q"), ord("Q"), 27):
            self._detail = None
        elif key == curses.KEY_UP:
            self._detail_scroll = max(0, self._detail_scroll - 1)
        elif key == curses.KEY_DOWN:
            lines = (data.get("servers", {})
                        .get(self._detail, {})
                        .get("log_lines", []))
            self._detail_scroll = min(
                max(0, len(lines) - 5), self._detail_scroll + 1
            )
        elif key in (24, 3):
            return False
        return True

    def _handle_prompt_key(self, key: int, req: _PromptRequest) -> bool:
        ch = chr(key).lower() if 32 <= key < 127 else ""
        if ch in req.opts:
            req.answer(ch)
        elif key == 27:
            req.answer(next(iter(req.opts)))
        elif key in (24, 3):
            req.answer(next(iter(req.opts)))
            return False
        return True


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------

def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="mwdeploy",
        description=(
            "MediaWiki deployment tool — wikioasis.org\n\n"
            "Run with no arguments to open the dashboard (shows the last deploy).\n"
            "Pass deployment flags to run a deploy with a live dashboard."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  mwdeploy                                                   # open dashboard
  mwdeploy --versions 1.45 --extension Echo --servers all --rollout
  mwdeploy --config --servers all --rollout
  mwdeploy --rsync --servers all --rollout
  mwdeploy --rsync --servers all --rollout --parallel 2      # 2 at a time
  mwdeploy --provision --servers mw-us-east-031
""",
    )
    what = p.add_argument_group("what to update in staging")
    what.add_argument("--core",      action="store_true",
                      help="git pull root of /srv/mediawiki-staging")
    what.add_argument("--mediawiki", action="store_true",
                      help="git pull MediaWiki core for selected version(s)")
    what.add_argument("--extension", metavar="NAME", action="append", default=[],
                      help="git pull an extension (repeatable; comma-separated ok)")
    what.add_argument("--skin",      metavar="NAME", action="append", default=[],
                      help="git pull a skin (repeatable; comma-separated ok)")
    what.add_argument("--config",    action="store_true",
                      help="git pull /srv/mediawiki-staging/config")
    what.add_argument("--patch",     metavar="PATCH", action="append", default=[],
                      help=("patch file relative to {prod_path}/scripts/extensions/patches/ "
                            "(repeatable); requires --patch-target"))
    what.add_argument("--patch-target", metavar="PATH", dest="patch_target", default="",
                      help="directory to patch, relative to {staging_path}/versions/<ver>/")

    p.add_argument("--versions",  metavar="VERSION",
                   help='version to target, e.g. "1.45" or "all"')
    p.add_argument("--servers",   metavar="SERVERS",
                   help='comma-separated server names or "all"')
    p.add_argument("--rsync",     action="store_true",
                   help="skip git pulls; deploy current staging content")
    p.add_argument("--rollout",   action="store_true",
                   help="depool each server before deploy, repool after")
    p.add_argument("--provision", action="store_true",
                   help="rsync /srv/mediawiki to new servers (no staging sync)")
    p.add_argument("--l10n",      action="store_true",
                   help="run rebuildLocalisationCache on staging and each mw server")
    p.add_argument("--force",     action="store_true",
                   help="continue even if canary check fails")
    p.add_argument("--parallel",  metavar="N", type=int, default=1,
                   help="deploy to N servers simultaneously (default: 1 = serial)")
    p.add_argument("--no-log", dest="no_log", action="store_true",
                   help="terminal only; skip file log and webhook notifications")
    return p


# ---------------------------------------------------------------------------
# Deploy thread
# ---------------------------------------------------------------------------

def _deploy_thread(args, cfg: dict, log: logging.Logger,
                   state: DeployState, prompter: Prompter):
    deploy_user    = cfg["deploy_user"]
    staging_path   = cfg["staging_path"]
    prod_path      = cfg["prod_path"]
    canary_vhost   = cfg["canary_vhost"]
    parallel       = max(1, args.parallel or 1)
    target_servers = resolve_servers(args.servers, cfg.get("mw_servers", []))

    rsync_targets: list[tuple[str, str]] | None = None   # set after version resolution

    def _run_one(server):
        return _deploy_server(server, cfg, args, log, state, prompter, rsync_targets)

    def _run_all(servers):
        if parallel <= 1:
            for s in servers:
                ok = _run_one(s)
                if not ok and prompter.is_aborted():
                    break
            return
        with concurrent.futures.ThreadPoolExecutor(max_workers=parallel) as pool:
            futs = {pool.submit(_run_one, s): s for s in servers}
            for fut in concurrent.futures.as_completed(futs):
                try:
                    fut.result()
                except Exception as e:
                    srv = futs[fut]
                    log.error("Unexpected error deploying %s: %s", srv, e)
                    state.update(srv, status=S_FAILED,
                                 line=f"Unexpected error: {e}")
                    if not args.force:
                        prompter.abort()
                if prompter.is_aborted() and not args.force:
                    for f in futs:
                        f.cancel()

    try:
        # ── Provision mode ─────────────────────────────────────────────
        if args.provision:
            if parallel > 1:
                log.info("Parallel provision: %d workers", parallel)
            _run_all(target_servers)
            return

        # ── Mark staging running immediately so TUI shows something ────
        patches    = args.patch  # list of paths relative to patches dir
        needs_ver  = args.mediawiki or args.extension or args.skin or bool(patches)
        extensions = [e for g in args.extension for e in g.split(",") if e.strip()]
        skins      = [s for g in args.skin      for s in g.split(",") if s.strip()]

        state.update(STAGING_KEY, status=S_RUNNING,
                     steps_total=1, steps_done=0, step="init",
                     line="Starting preparation…")

        # ── Resolve versions ────────────────────────────────────────────
        versions: list[str] = []
        if not args.rsync and needs_ver:
            ver_arg = args.versions or "all"
            if not args.versions:
                state.update(STAGING_KEY,
                             line="--versions not set; defaulting to 'all'")
                log.info("--versions not specified; defaulting to 'all'")
            state.update(STAGING_KEY, line=f"Resolving versions ({ver_arg})…")
            try:
                versions = resolve_versions(ver_arg, staging_path)
            except SystemExit as e:
                state.update(STAGING_KEY, status=S_FAILED,
                             line=f"Cannot resolve versions: {e}")
                return
            if not versions:
                state.update(STAGING_KEY, status=S_FAILED,
                             line=f"No versions found under {staging_path}/versions/")
                return
            state.update(STAGING_KEY,
                         line=(f"Targeting {len(versions)} version(s): "
                               f"{', '.join(versions)}"))

        if extensions:
            state.update(STAGING_KEY, line=f"Extensions: {', '.join(extensions)}")
        if skins:
            state.update(STAGING_KEY, line=f"Skins: {', '.join(skins)}")
        if patches and not args.patch_target:
            state.update(STAGING_KEY, status=S_FAILED,
                         line="--patch-target is required when using --patch")
            return
        if patches:
            state.update(STAGING_KEY,
                         line=(f"Patches: {', '.join(os.path.basename(p) for p in patches)}"
                               f" → {args.patch_target}"))

        rsync_targets = _build_rsync_targets(
            args, staging_path, prod_path, versions, extensions, skins
        )
        if rsync_targets != [(staging_path, prod_path)]:
            labels = [os.path.relpath(s, staging_path) for s, _ in rsync_targets]
            state.update(STAGING_KEY,
                         line=f"Targeted rsync: {', '.join(labels)}")

        # ── Compute staging step list ───────────────────────────────────
        staging_steps: list[str] = []
        if not args.rsync:
            if args.core:   staging_steps.append("git pull core")
            if args.config: staging_steps.append("git pull config")
            for ver in versions:
                if args.mediawiki:
                    staging_steps.append(f"git pull mw/{ver}")
                for ext in extensions:
                    staging_steps.append(f"git pull ext/{ext}")
                for skin in skins:
                    staging_steps.append(f"git pull skin/{skin}")
        for ver in versions:
            for pfile in patches:
                staging_steps.append(f"patch {os.path.basename(pfile)} ({ver})")
        staging_steps += ["local rsync"]
        if args.l10n:
            staging_steps += ["l10n rebuild"]
        staging_steps += ["canary"]
        staging_done = 0

        state.update(STAGING_KEY, steps_total=len(staging_steps),
                     steps_done=0, step="",
                     line=f"Plan: {len(staging_steps)} step(s)")

        # Helper: git pull one path, update state, return False on failure.
        def _do_git_pull(path: str, label: str) -> bool:
            nonlocal staging_done
            state.update(STAGING_KEY, step=label, line=f"git pull  {label}…")
            try:
                r = git_pull(path, log)
                out = (r.stdout or r.stderr or "").strip()
                first = out.splitlines()[0][:120] if out else "already up to date"
                staging_done += 1
                state.update(STAGING_KEY, steps_done=staging_done,
                             line=f"{label}: {first}")
                return True
            except RuntimeError as e:
                full = str(e)
                # _run_check formats as: "<prefix>\nstdout: ...\nstderr: ..."
                # Prefer the actual git stderr over the generic prefix line.
                git_msg = ""
                for ln in full.splitlines():
                    if ln.startswith("stderr:"):
                        git_msg = ln[7:].strip()
                        break
                    if ln.startswith("stdout:") and not git_msg:
                        git_msg = ln[7:].strip()
                msg = (git_msg or full.splitlines()[0])[:200]
                state.update(STAGING_KEY, status=S_FAILED,
                             line=f"FAILED {label}: {msg}")
                log.error("git pull failed for %s:\n%s", label, full)
                return False

        # ── Phase 1: git pulls ──────────────────────────────────────────
        if not args.rsync:
            if args.core:
                if not _do_git_pull(staging_path, "core"):
                    return

            if args.config:
                if not _do_git_pull(
                        os.path.join(staging_path, "config"), "config"):
                    return

            for ver in versions:
                vp = os.path.join(staging_path, "versions", ver)
                if args.mediawiki:
                    if not _do_git_pull(vp, f"mw/{ver}"):
                        return
                for ext in extensions:
                    if not _do_git_pull(
                            os.path.join(vp, "extensions", ext),
                            f"ext/{ext}"):
                        return
                for skin in skins:
                    if not _do_git_pull(
                            os.path.join(vp, "skins", skin),
                            f"skin/{skin}"):
                        return
        else:
            state.update(STAGING_KEY, step="--rsync mode",
                         line="--rsync: skipping git pulls")

        # ── Phase 1.5: apply patches ────────────────────────────────────
        if patches:
            patches_base = os.path.join(prod_path, "scripts", "extensions", "patches")
            for ver in versions:
                for pfile in patches:
                    label = f"patch {os.path.basename(pfile)} ({ver})"
                    patch_abs   = os.path.join(patches_base, pfile)
                    target_dir  = os.path.join(staging_path, "versions", ver,
                                               args.patch_target)
                    state.update(STAGING_KEY, step=label,
                                 line=f"Applying {os.path.basename(pfile)} → {args.patch_target}…")
                    try:
                        apply_patch(patch_abs, target_dir, log)
                        staging_done += 1
                        state.update(STAGING_KEY, steps_done=staging_done,
                                     line=f"{label}: applied")
                    except RuntimeError as e:
                        full = str(e)
                        msg  = ""
                        for ln in full.splitlines():
                            if ln.startswith("stderr:"):
                                msg = ln[7:].strip()
                                break
                            if ln.startswith("stdout:") and not msg:
                                msg = ln[7:].strip()
                        msg = (msg or full.splitlines()[0])[:200]
                        state.update(STAGING_KEY, status=S_FAILED,
                                     line=f"FAILED {label}: {msg}")
                        log.error("Patch failed for %s on %s:\n%s", pfile, ver, full)
                        return

        # ── Phase 2: local rsync ────────────────────────────────────────
        is_full_sync = rsync_targets == [(staging_path, prod_path)]
        if is_full_sync:
            state.update(STAGING_KEY, step="local rsync",
                         line=f"Syncing {staging_path} → {prod_path}…")
            try:
                rsync_local(staging_path, prod_path, log)
            except RuntimeError as e:
                log.error("Local rsync failed: %s", e)
                state.update(STAGING_KEY, status=S_FAILED,
                             line=f"Local rsync FAILED: {e}")
                return
        else:
            state.update(STAGING_KEY, step="local rsync",
                         line=f"Targeted rsync: {len(rsync_targets)} path(s)…")
            for i, (t_src, t_dst) in enumerate(rsync_targets, 1):
                lbl = os.path.relpath(t_src, staging_path)
                state.update(STAGING_KEY,
                             line=f"rsync {lbl}  ({i}/{len(rsync_targets)})…")
                try:
                    rsync_local_path(t_src, t_dst, log)
                except RuntimeError as e:
                    log.error("Local rsync failed for %s: %s", lbl, e)
                    state.update(STAGING_KEY, status=S_FAILED,
                                 line=f"Local rsync FAILED {lbl}: {e}")
                    return
        staging_done += 1
        state.update(STAGING_KEY, steps_done=staging_done,
                     line="Local rsync complete")

        # ── Phase 2.5: l10n rebuild on staging ─────────────────────────
        if args.l10n:
            state.update(STAGING_KEY, step="l10n rebuild",
                         line="Rebuilding localisation cache on staging…")
            try:
                l10n_rebuild(STAGING_KEY, cfg, log)
                staging_done += 1
                state.update(STAGING_KEY, steps_done=staging_done,
                             line="L10n cache rebuilt on staging")
            except RuntimeError as e:
                log.error("L10n rebuild failed on staging: %s", e)
                state.update(STAGING_KEY, status=S_FAILED,
                             line=f"L10n rebuild FAILED: {e}")
                return

        # ── Phase 3: canary on staging ──────────────────────────────────
        state.update(STAGING_KEY, step="canary",
                     line="Running canary check on localhost…")
        if not canary_check(STAGING_KEY, canary_vhost, log,
                            deploy_user=deploy_user,
                            force=args.force, prompter=prompter):
            state.update(STAGING_KEY, status=S_FAILED,
                         line="Canary FAILED — deploy aborted")
            return

        staging_done += 1
        state.update(STAGING_KEY, status=S_DONE,
                     steps_done=staging_done, step="",
                     line="Staging ready ✓")

        if not target_servers:
            return

        # ── Phase 4: rolling deploy ─────────────────────────────────────
        if parallel > 1:
            log.info("Parallel deploy: %d workers across %d servers",
                     parallel, len(target_servers))
        _run_all(target_servers)

    except Exception as e:
        # Catch-all so unexpected exceptions update state rather than
        # silently dying, leaving STAGING_KEY stuck in S_RUNNING.
        log.error("Unexpected error in deploy thread: %s", e, exc_info=True)
        staging_st = state.snapshot()["servers"].get(STAGING_KEY, {}).get("status")
        if staging_st == S_RUNNING:
            state.update(STAGING_KEY, status=S_FAILED,
                         line=f"Unexpected error: {e}")
    finally:
        state.mark_done()


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = _build_parser()
    args   = parser.parse_args()
    cfg    = load_config()

    global _SSH_OPTS
    deploy_user  = cfg.get("deploy_user", "mwdeploy")
    ssh_identity = cfg.get("ssh_identity",
                           f"/home/{deploy_user}/.ssh/id_ed25519")
    _SSH_OPTS = [
        "-i", ssh_identity,
        "-o", "StrictHostKeyChecking=no",
        "-o", "BatchMode=yes",
        "-o", "ControlMaster=auto",
        "-o", "ControlPath=/tmp/mwdeploy-ssh-%r@%h:%p",
        "-o", "ControlPersist=60s",
    ]

    deploy_flags = any([
        args.core, args.mediawiki, args.extension, args.skin,
        args.config, args.rsync, args.provision,
    ])

    if not deploy_flags:
        Dashboard(state=None, prompter=None, cfg=cfg).run()
        return

    target_servers = resolve_servers(args.servers, cfg.get("mw_servers", []))
    all_servers    = (
        ([STAGING_KEY] + target_servers) if not args.provision
        else target_servers
    )
    state    = DeployState(all_servers)
    prompter = Prompter()

    if args.no_log:
        log = _setup_logging(cfg, no_log=True, suppress_stdout=False)
        _notify(log, cfg, True,
                f"mwdeploy starting — targets: {target_servers or 'staging only'}")
        _deploy_thread(args, cfg, log, state, prompter)
    else:
        log = _setup_logging(cfg, no_log=False, suppress_stdout=True)
        _notify(log, cfg, False,
                f"mwdeploy starting — targets: {target_servers or 'staging only'}")
        t = threading.Thread(
            target=_deploy_thread,
            args=(args, cfg, log, state, prompter),
            daemon=True,
        )
        t.start()
        Dashboard(state=state, prompter=prompter, cfg=cfg).run()
        t.join(timeout=5)

    snap   = state.snapshot()
    failed = [s for s, d in snap["servers"].items() if d["status"] == S_FAILED]
    if failed:
        _notify(log, cfg, args.no_log,
                f"DEPLOY FINISHED WITH FAILURES: {failed}",
                level=logging.ERROR)
        sys.exit(1)
    else:
        _notify(log, cfg, args.no_log,
                f"Deploy complete — {len(all_servers)} server(s) updated")


if __name__ == "__main__":
    main()
