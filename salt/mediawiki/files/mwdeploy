#!/usr/bin/env python3
"""
mwdeploy — MediaWiki deployment tool for wikioasis.org

Run with no arguments to open the deployment dashboard.
Pass deployment flags to run a deploy (dashboard opens automatically).
"""

import argparse
import concurrent.futures
import curses
import json
import logging
import os
import subprocess
import sys
import threading
import time
import urllib.request
import urllib.error
from datetime import datetime, timezone
from pathlib import Path

import yaml

CONFIG_PATH = "/etc/mwdeploy/config.yaml"
ROLLBACK_BASE = "/tmp/mwdeploy-rollback"
STATE_FILE = "/var/log/mwdeploy-state.json"

# Used by all SSH/rsync calls; populated once in main() from config
_SSH_OPTS: list[str] = []

# Per-server status values
S_PENDING  = "pending"
S_RUNNING  = "running"
S_DONE     = "done"
S_FAILED   = "failed"
S_ROLLBACK = "rolled_back"
S_SKIPPED  = "skipped"

_STATUS_ICON = {
    S_PENDING:  ("○ pending",     "pending"),
    S_RUNNING:  ("⟳ running",     "running"),
    S_DONE:     ("✓ done",        "done"),
    S_FAILED:   ("✗ failed",      "failed"),
    S_ROLLBACK: ("⤺ rolled back", "rolled_back"),
    S_SKIPPED:  ("– skipped",     "skipped"),
}


# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

def load_config() -> dict:
    try:
        with open(CONFIG_PATH) as f:
            return yaml.safe_load(f)
    except FileNotFoundError:
        sys.exit(f"Config not found: {CONFIG_PATH}")
    except yaml.YAMLError as e:
        sys.exit(f"Bad config: {e}")


# ---------------------------------------------------------------------------
# Deployment state  (thread-safe, persisted to STATE_FILE)
# ---------------------------------------------------------------------------

class DeployState:
    MAX_LOG = 50  # lines kept per server

    def __init__(self, servers: list[str]):
        self._lock = threading.Lock()
        self._started = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        self._servers: dict[str, dict] = {
            s: {"status": S_PENDING, "log_lines": [], "snapshot": None}
            for s in servers
        }
        self._done = threading.Event()

    # --- writers (called from deploy thread) --------------------------------

    def update(self, server: str, *, status: str | None = None,
               line: str | None = None, snapshot: str | None = None):
        ts = datetime.now(timezone.utc).strftime("%H:%M:%S")
        with self._lock:
            row = self._servers.setdefault(
                server, {"status": S_PENDING, "log_lines": [], "snapshot": None}
            )
            if status is not None:
                row["status"] = status
            if line is not None:
                row["log_lines"].append(f"{ts}  {line}")
                row["log_lines"] = row["log_lines"][-self.MAX_LOG:]
            if snapshot is not None:
                row["snapshot"] = snapshot
        self._save()

    def mark_done(self):
        self._done.set()

    def is_done(self) -> bool:
        return self._done.is_set()

    # --- readers (called from UI thread) ------------------------------------

    def snapshot(self) -> dict:
        with self._lock:
            return {
                "started": self._started,
                "servers": {k: dict(v) for k, v in self._servers.items()},
            }

    def server_snapshot_path(self, server: str) -> str | None:
        with self._lock:
            return self._servers.get(server, {}).get("snapshot")

    # --- persistence --------------------------------------------------------

    def _save(self):
        try:
            data = self.snapshot()
            tmp = STATE_FILE + ".tmp"
            with open(tmp, "w") as f:
                json.dump(data, f, indent=2)
            os.replace(tmp, STATE_FILE)
        except OSError:
            pass

    @staticmethod
    def load_file() -> dict | None:
        try:
            with open(STATE_FILE) as f:
                return json.load(f)
        except (FileNotFoundError, json.JSONDecodeError, OSError):
            return None


# ---------------------------------------------------------------------------
# Logging / webhook
# ---------------------------------------------------------------------------

class _WebhookHandler(logging.Handler):
    def __init__(self, discord: str = "", slack: str = ""):
        super().__init__()
        self._discord = discord
        self._slack = slack

    def _post(self, url: str, payload: dict):
        data = json.dumps(payload).encode()
        req = urllib.request.Request(
            url, data=data,
            headers={"Content-Type": "application/json"}, method="POST"
        )
        try:
            urllib.request.urlopen(req, timeout=5)
        except Exception:
            pass

    def emit(self, record):
        msg = self.format(record)
        if self._discord:
            self._post(self._discord, {"content": msg})
        if self._slack:
            self._post(self._slack, {"text": msg})


def _setup_logging(cfg: dict, no_log: bool) -> logging.Logger:
    log = logging.getLogger("mwdeploy")
    log.setLevel(logging.DEBUG)
    fmt = logging.Formatter(
        "%(asctime)s [%(levelname)s] %(message)s", datefmt="%Y-%m-%dT%H:%M:%SZ"
    )

    ch = logging.StreamHandler(sys.stdout)
    ch.setFormatter(fmt)
    log.addHandler(ch)

    if no_log:
        return log

    log_file = cfg.get("log_file", "/var/log/mwdeploy.log")
    try:
        fh = logging.FileHandler(log_file)
        fh.setFormatter(fmt)
        log.addHandler(fh)
    except OSError as e:
        log.warning("Cannot open log file %s: %s", log_file, e)

    webhooks = cfg.get("webhooks", {})
    discord = webhooks.get("discord") or ""
    slack = webhooks.get("slack") or ""
    if discord or slack:
        wh = _WebhookHandler(discord, slack)
        wh.setLevel(logging.WARNING)
        wh.setFormatter(logging.Formatter("[mwdeploy] %(levelname)s: %(message)s"))
        log.addHandler(wh)

    return log


def _notify(log: logging.Logger, cfg: dict, no_log: bool, msg: str,
            level: int = logging.INFO):
    """Always post a banner-level message (start/finish/abort) to all sinks."""
    log.log(level, msg)
    if no_log:
        return
    webhooks = cfg.get("webhooks", {})
    discord = webhooks.get("discord") or ""
    slack = webhooks.get("slack") or ""
    if not discord and not slack:
        return
    h = _WebhookHandler(discord, slack)
    payload = f"[mwdeploy] {msg}"
    if discord:
        h._post(discord, {"content": payload})
    if slack:
        h._post(slack, {"text": payload})


# ---------------------------------------------------------------------------
# Shell
# ---------------------------------------------------------------------------

def _run(cmd: list, **kwargs) -> subprocess.CompletedProcess:
    logging.getLogger("mwdeploy").debug("$ %s", " ".join(str(c) for c in cmd))
    return subprocess.run(cmd, capture_output=True, text=True, **kwargs)


def _run_check(cmd: list, error_prefix: str = "Command failed", **kwargs):
    r = _run(cmd, **kwargs)
    if r.returncode != 0:
        raise RuntimeError(
            f"{error_prefix}\nstdout: {r.stdout.strip()}\nstderr: {r.stderr.strip()}"
        )
    return r


# ---------------------------------------------------------------------------
# Git
# ---------------------------------------------------------------------------

def git_pull(path: str, log: logging.Logger):
    log.info("git pull  %s", path)
    _run_check(
        ["sudo", "-u", "www-data", "git", "-C", path, "pull", "--ff-only"],
        error_prefix=f"git pull failed in {path}",
    )


# ---------------------------------------------------------------------------
# Canary check
# ---------------------------------------------------------------------------

def canary_check(host: str, vhost: str, log: logging.Logger,
                 deploy_user: str = "mwdeploy",
                 force: bool = False, retries: int = 3,
                 prompt_lock: threading.Lock | None = None,
                 abort_event: threading.Event | None = None) -> bool:
    """
    SSH into the target (or run locally) and curl http://127.0.0.1/wiki/Main_Page
    with -H "Host: <vhost>".  Expects HTTP 200 and "mediawiki" in the body.

    In parallel mode pass prompt_lock so only one thread prompts the user at a
    time, and abort_event so a prior "no" is respected without re-prompting.
    """
    curl_cmd = (
        f'code=$(curl -sS --max-time 15 --location'
        f' -H "Host: {vhost}"'
        f' -o /tmp/mwdeploy-canary'
        f' -w "%{{http_code}}"'
        f' "http://127.0.0.1/wiki/Main_Page" 2>&1);'
        f' echo "HTTP_CODE=$code";'
        f' grep -qi mediawiki /tmp/mwdeploy-canary'
        f' && echo "HAS_MW=1" || echo "HAS_MW=0";'
        f' rm -f /tmp/mwdeploy-canary'
    )

    log.info("Canary  %s  (Host: %s)", host, vhost)
    code = "???"

    for attempt in range(1, retries + 1):
        try:
            if host == "localhost":
                r = _run(["bash", "-c", curl_cmd])
            else:
                r = _run(["ssh"] + _SSH_OPTS + [f"{deploy_user}@{host}", curl_cmd])
            output = r.stdout

            code_line = next(
                (ln for ln in output.splitlines() if ln.startswith("HTTP_CODE=")), ""
            )
            mw_line = next(
                (ln for ln in output.splitlines() if ln.startswith("HAS_MW=")), ""
            )
            code = code_line.replace("HTTP_CODE=", "").strip()
            has_mw = mw_line.strip() == "HAS_MW=1"

            if code == "200" and has_mw:
                log.info("Canary OK  %s  (HTTP 200)", host)
                return True

            reason = f"HTTP {code}" if code != "200" else "no MediaWiki content in body"
            log.warning("Canary attempt %d/%d failed on %s: %s", attempt, retries, host, reason)
        except Exception as e:
            log.warning("Canary attempt %d/%d error on %s: %s", attempt, retries, host, e)

        if attempt < retries:
            time.sleep(3)

    if force:
        log.warning("Canary failed on %s — --force set, continuing", host)
        return True

    # Serialise prompts so parallel threads don't stomp each other
    lock = prompt_lock or threading.Lock()
    with lock:
        if abort_event and abort_event.is_set():
            log.warning("Canary failed on %s; aborting (already decided)", host)
            return False
        ans = input(f"\nCanary failed on {host}. Continue? [y/N] ").strip().lower()
        if ans != "y" and abort_event:
            abort_event.set()
    return ans == "y"


# ---------------------------------------------------------------------------
# HAProxy
# ---------------------------------------------------------------------------

def _haproxy_cmd(proxy: str, deploy_user: str, socket: str, command: str,
                 log: logging.Logger):
    remote = f"printf '{command}\\n' | socat stdio {socket}"
    r = _run(["ssh"] + _SSH_OPTS + [f"{deploy_user}@{proxy}", remote])
    if r.returncode != 0:
        raise RuntimeError(f"HAProxy cmd on {proxy} failed: {r.stderr.strip()}")
    return r.stdout


def _depool(proxy: str, deploy_user: str, socket: str,
            backend: str, server: str, log: logging.Logger):
    log.info("Depooling  %s/%s  via %s", backend, server, proxy)
    _haproxy_cmd(proxy, deploy_user, socket, f"disable server {backend}/{server}", log)


def _repool(proxy: str, deploy_user: str, socket: str,
            backend: str, server: str, log: logging.Logger):
    log.info("Repooling  %s/%s  via %s", backend, server, proxy)
    _haproxy_cmd(proxy, deploy_user, socket, f"enable server {backend}/{server}", log)


def _depool_all(cfg: dict, server: str, log: logging.Logger):
    for p in cfg.get("proxy_servers", []):
        try:
            _depool(p, cfg["deploy_user"], cfg["haproxy_socket"],
                    cfg["haproxy_backend"], server, log)
        except RuntimeError as e:
            log.error("Depool %s from %s: %s", server, p, e)


def _repool_all(cfg: dict, server: str, log: logging.Logger):
    for p in cfg.get("proxy_servers", []):
        try:
            _repool(p, cfg["deploy_user"], cfg["haproxy_socket"],
                    cfg["haproxy_backend"], server, log)
        except RuntimeError as e:
            log.error("Repool %s into %s: %s", server, p, e)


# ---------------------------------------------------------------------------
# Rsync
# ---------------------------------------------------------------------------

def _rsync_base(extra_excludes: list[str]) -> list[str]:
    cmd = ["rsync", "-az", "--checksum", "--delete"]
    for ex in ["cache/"] + extra_excludes:
        cmd += ["--exclude", ex]
    return cmd


def rsync_local(src: str, dst: str, log: logging.Logger, provision: bool = False):
    log.info("Local rsync  %s → %s", src, dst)
    excludes = [] if provision else ["cw_cache/"]
    _run_check(
        _rsync_base(excludes) + [src.rstrip("/") + "/", dst.rstrip("/") + "/"],
        error_prefix="Local rsync failed",
    )


def rsync_remote(src: str, host: str, dst: str, deploy_user: str,
                 log: logging.Logger, provision: bool = False):
    log.info("Remote rsync  %s → %s:%s", src, host, dst)
    excludes = [] if provision else ["cw_cache/"]
    ssh_cmd = "ssh " + " ".join(_SSH_OPTS)
    _run_check(
        _rsync_base(excludes) + [
            "--rsync-path=sudo rsync",
            "-e", ssh_cmd,
            src.rstrip("/") + "/",
            f"{deploy_user}@{host}:{dst.rstrip('/')}/",
        ],
        error_prefix=f"Remote rsync to {host} failed",
    )


# ---------------------------------------------------------------------------
# Rollback
# ---------------------------------------------------------------------------

def save_rollback(host: str, deploy_user: str, prod_path: str,
                  log: logging.Logger) -> str | None:
    ts = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")
    snap = f"{ROLLBACK_BASE}-{ts}"
    log.info("Saving rollback snapshot on %s: %s", host, snap)
    remote_cmd = (
        f"rsync -a --exclude cache/ --exclude cw_cache/ "
        f"{prod_path.rstrip('/')}/ {snap}/"
    )
    r = _run(["ssh"] + _SSH_OPTS + [f"{deploy_user}@{host}", remote_cmd])
    if r.returncode != 0:
        log.warning("Could not snapshot %s: %s", host, r.stderr.strip())
        return None
    return snap


def do_rollback(host: str, deploy_user: str, snap: str, prod_path: str,
                log: logging.Logger) -> bool:
    log.warning("Rolling back %s from %s", host, snap)
    remote_cmd = f"sudo rsync -a --delete {snap}/ {prod_path.rstrip('/')}/"
    r = _run(["ssh"] + _SSH_OPTS + [f"{deploy_user}@{host}", remote_cmd])
    if r.returncode != 0:
        log.error("Rollback failed on %s: %s", host, r.stderr.strip())
        return False
    log.info("Rollback complete on %s", host)
    return True


# ---------------------------------------------------------------------------
# Version / server resolution
# ---------------------------------------------------------------------------

def resolve_versions(arg: str, staging_path: str) -> list[str]:
    if arg == "all":
        vd = Path(staging_path) / "versions"
        if not vd.is_dir():
            sys.exit(f"versions/ not found under {staging_path}")
        return sorted(d.name for d in vd.iterdir() if d.is_dir())
    return [arg]


def resolve_servers(arg: str | None, all_servers: list) -> list[str]:
    if arg is None or arg == "all":
        return list(all_servers)
    return [s.strip() for s in arg.split(",") if s.strip()]


# ---------------------------------------------------------------------------
# Deploy one server (called from deploy thread)
# ---------------------------------------------------------------------------

def _deploy_server(server: str, cfg: dict, args, log: logging.Logger,
                   state: DeployState,
                   prompt_lock: threading.Lock | None = None,
                   abort_event: threading.Event | None = None) -> bool:
    """Deploy to one server.  Returns True on success, False on failure."""

    # Respect an abort signalled by another parallel thread
    if abort_event and abort_event.is_set():
        state.update(server, status=S_SKIPPED, line="Skipped — deploy aborted by earlier failure")
        return True   # skipped ≠ failed; don't add to the failure list

    deploy_user = cfg["deploy_user"]
    staging_path = cfg["staging_path"]
    prod_path = cfg["prod_path"]
    canary_vhost = cfg["canary_vhost"]
    lock = prompt_lock or threading.Lock()

    state.update(server, status=S_RUNNING, line="Starting deploy")

    snap = None
    if args.rollout:
        snap = save_rollback(server, deploy_user, prod_path, log)
        if snap:
            state.update(server, line=f"Snapshot saved: {snap}", snapshot=snap)
        _depool_all(cfg, server, log)
        state.update(server, line="Depooled from HAProxy")

    src = prod_path if args.provision else staging_path
    try:
        rsync_remote(src, server, prod_path, deploy_user, log,
                     provision=args.provision)
        state.update(server, line="Rsync complete")
    except RuntimeError as e:
        log.error("rsync failed for %s: %s", server, e)
        state.update(server, status=S_FAILED, line=f"Rsync FAILED: {e}")
        if args.rollout:
            _repool_all(cfg, server, log)
            state.update(server, line="Repooled after rsync failure")
        if not args.force and abort_event:
            abort_event.set()
        return False

    if not canary_check(server, canary_vhost, log, deploy_user=deploy_user,
                        force=args.force, prompt_lock=lock,
                        abort_event=abort_event):
        log.error("Canary failed on %s", server)
        state.update(server, status=S_FAILED, line="Canary check FAILED")

        if snap and args.rollout:
            with lock:
                ans = input(f"Roll back {server}? [Y/n] ").strip().lower()
            if ans != "n":
                ok = do_rollback(server, deploy_user, snap, prod_path, log)
                state.update(server,
                             status=S_ROLLBACK if ok else S_FAILED,
                             line="Rolled back" if ok else "Rollback FAILED")

        if args.rollout:
            _repool_all(cfg, server, log)
            state.update(server, line="Repooled")

        if not args.force:
            with lock:
                # Another thread may have already asked and got "no"
                if abort_event and abort_event.is_set():
                    return False
                ans = input("Continue with remaining servers? [y/N] ").strip().lower()
                if ans != "y" and abort_event:
                    abort_event.set()
        return False

    state.update(server, line="Canary OK")
    if args.rollout:
        _repool_all(cfg, server, log)
        state.update(server, line="Repooled into HAProxy")

    state.update(server, status=S_DONE, line="Deploy complete")
    return True


# ---------------------------------------------------------------------------
# Dashboard TUI
# ---------------------------------------------------------------------------

# Color pair IDs
_C_NAME    = 1   # server name — bright green bold
_C_DONE    = 2   # ✓ done
_C_FAIL    = 3   # ✗ failed  — red
_C_RUNNING = 4   # ⟳ running — yellow
_C_PENDING = 5   # ○ pending — dim
_C_LOG     = 6   # log lines — green (normal weight)
_C_BAR     = 7   # status bar
_C_SEL     = 8   # selected row


def _shorten(name: str) -> str:
    """Drop the FQDN suffix for display."""
    return name.split(".")[0]


class Dashboard:
    REFRESH_MS = 300
    LOG_LINES = 10   # shown per server in main view

    def __init__(self, state: DeployState | None, cfg: dict):
        self._state = state          # live (during deploy) or None
        self._cfg = cfg
        self._selected = 0
        self._detail: str | None = None   # server name in detail view
        self._detail_scroll = 0
        self._confirm_rollback = False
        self._status_msg = ""        # transient message on bar
        self._lock = threading.Lock()

    # ------------------------------------------------------------------
    # Public entry point
    # ------------------------------------------------------------------

    def run(self):
        curses.wrapper(self._main)

    # ------------------------------------------------------------------
    # Curses main loop
    # ------------------------------------------------------------------

    def _main(self, scr):
        self._init_colors()
        curses.curs_set(0)
        scr.nodelay(True)
        scr.timeout(self.REFRESH_MS)

        while True:
            data = self._data()
            servers = list(data.get("servers", {}).keys())

            if self._detail:
                sdata = data.get("servers", {}).get(self._detail, {})
                self._draw_detail(scr, self._detail, sdata)
            else:
                self._draw_main(scr, data, servers)
                if self._confirm_rollback and servers:
                    self._draw_confirm(scr, servers)

            try:
                key = scr.getch()
            except curses.error:
                key = -1

            if key == -1:
                # No key: check if deploy finished and we're in no-deploy mode
                continue

            if self._confirm_rollback:
                if not self._handle_confirm_key(key, servers):
                    return   # Ctrl+X from confirm
                continue

            if self._detail:
                if not self._handle_detail_key(key, data):
                    return
                continue

            if not self._handle_main_key(key, servers):
                return   # exit

    # ------------------------------------------------------------------
    # Data source
    # ------------------------------------------------------------------

    def _data(self) -> dict:
        if self._state:
            return self._state.snapshot()
        d = DeployState.load_file()
        return d if d else {"started": "", "servers": {}}

    # ------------------------------------------------------------------
    # Color setup
    # ------------------------------------------------------------------

    def _init_colors(self):
        curses.start_color()
        curses.use_default_colors()
        curses.init_pair(_C_NAME,    curses.COLOR_GREEN,  -1)
        curses.init_pair(_C_DONE,    curses.COLOR_GREEN,  -1)
        curses.init_pair(_C_FAIL,    curses.COLOR_RED,    -1)
        curses.init_pair(_C_RUNNING, curses.COLOR_YELLOW, -1)
        curses.init_pair(_C_PENDING, curses.COLOR_WHITE,  -1)
        curses.init_pair(_C_LOG,     curses.COLOR_GREEN,  -1)
        curses.init_pair(_C_BAR,     curses.COLOR_BLACK,  curses.COLOR_GREEN)
        curses.init_pair(_C_SEL,     curses.COLOR_BLACK,  curses.COLOR_GREEN)

    def _status_attr(self, status: str) -> int:
        return {
            S_DONE:     curses.color_pair(_C_DONE)    | curses.A_BOLD,
            S_FAILED:   curses.color_pair(_C_FAIL)    | curses.A_BOLD,
            S_RUNNING:  curses.color_pair(_C_RUNNING) | curses.A_BOLD,
            S_ROLLBACK: curses.color_pair(_C_RUNNING),
            S_SKIPPED:  curses.color_pair(_C_PENDING),
        }.get(status, curses.color_pair(_C_PENDING))

    # ------------------------------------------------------------------
    # Main view
    # ------------------------------------------------------------------

    def _draw_main(self, scr, data: dict, servers: list):
        h, w = scr.getmaxyx()
        scr.erase()

        # ── title ──────────────────────────────────────────────────────
        title = "mwdeploy"
        started = data.get("started", "")
        right = f"started {started}" if started else ""
        self._addstr(scr, 0, 2, title, curses.color_pair(_C_NAME) | curses.A_BOLD)
        if right and w - len(right) - 3 > len(title) + 4:
            self._addstr(scr, 0, w - len(right) - 2, right,
                         curses.color_pair(_C_LOG))

        row = 2
        srv_data = data.get("servers", {})

        for idx, name in enumerate(servers):
            if row >= h - 1:
                break

            sd = srv_data.get(name, {})
            status = sd.get("status", S_PENDING)
            icon, _ = _STATUS_ICON.get(status, (status, status))
            short = _shorten(name)
            selected = (idx == self._selected)

            # ── server name row ────────────────────────────────────────
            if selected:
                self._addstr(scr, row, 0, " " * w, curses.color_pair(_C_SEL))
                label = f"  {short:<26}{icon}"
                self._addstr(scr, row, 0, label, curses.color_pair(_C_SEL) | curses.A_BOLD)
            else:
                self._addstr(scr, row, 2, f"{short:<26}",
                             curses.color_pair(_C_NAME) | curses.A_BOLD)
                self._addstr(scr, row, 28, icon, self._status_attr(status))

            row += 1

            # ── log lines ──────────────────────────────────────────────
            lines = sd.get("log_lines", [])[-self.LOG_LINES:]
            for line in lines:
                if row >= h - 1:
                    break
                self._addstr(scr, row, 4, line[:w - 5], curses.color_pair(_C_LOG))
                row += 1

            row += 1   # blank separator

        # ── status bar ─────────────────────────────────────────────────
        bar = self._status_msg if self._status_msg else (
            "  [↑↓] select   [Ctrl+O] detailed logs"
            "   [Ctrl+R] rollback   [Ctrl+X] exit"
        )
        self._draw_bar(scr, bar)
        scr.refresh()

    # ------------------------------------------------------------------
    # Detail view (Ctrl+O)
    # ------------------------------------------------------------------

    def _draw_detail(self, scr, name: str, sdata: dict):
        h, w = scr.getmaxyx()
        scr.erase()

        status = sdata.get("status", S_PENDING)
        icon, _ = _STATUS_ICON.get(status, (status, status))
        heading = f"  {_shorten(name)}   {icon}"
        self._addstr(scr, 0, 0, heading,
                     curses.color_pair(_C_NAME) | curses.A_BOLD)
        self._addstr(scr, 1, 0, "─" * min(w, 72), curses.color_pair(_C_LOG))

        lines = sdata.get("log_lines", [])
        visible = lines[self._detail_scroll: self._detail_scroll + h - 4]
        for i, line in enumerate(visible):
            self._addstr(scr, 2 + i, 2, line[:w - 3], curses.color_pair(_C_LOG))

        if not lines:
            self._addstr(scr, 3, 4, "(no log lines yet)", curses.color_pair(_C_PENDING))

        self._draw_bar(scr, "  [↑↓] scroll   [Q / Esc] back   [Ctrl+X] exit")
        scr.refresh()

    # ------------------------------------------------------------------
    # Rollback confirmation overlay
    # ------------------------------------------------------------------

    def _draw_confirm(self, scr, servers: list):
        h, w = scr.getmaxyx()
        name = servers[self._selected] if self._selected < len(servers) else "?"
        short = _shorten(name)
        lines = [
            "",
            f"  Roll back {short}?",
            "",
            "  This restores the pre-deploy snapshot on that server,",
            "  then repools it into HAProxy.",
            "",
            "  [Y] confirm rollback        [N / Esc] cancel",
            "",
        ]
        box_w = 58
        box_h = len(lines)
        y0 = max(0, (h - box_h) // 2)
        x0 = max(0, (w - box_w) // 2)
        for i, line in enumerate(lines):
            self._addstr(scr, y0 + i, x0, line.ljust(box_w)[:box_w],
                         curses.color_pair(_C_BAR))
        scr.refresh()

    # ------------------------------------------------------------------
    # Shared bar
    # ------------------------------------------------------------------

    def _draw_bar(self, scr, text: str):
        h, w = scr.getmaxyx()
        self._addstr(scr, h - 1, 0, text.ljust(w)[:w], curses.color_pair(_C_BAR))

    # ------------------------------------------------------------------
    # Safe addstr
    # ------------------------------------------------------------------

    @staticmethod
    def _addstr(scr, y: int, x: int, text: str, attr: int = 0):
        h, w = scr.getmaxyx()
        if y < 0 or y >= h or x < 0 or x >= w:
            return
        try:
            scr.addstr(y, x, text[:max(0, w - x)], attr)
        except curses.error:
            pass

    # ------------------------------------------------------------------
    # Key handlers
    # ------------------------------------------------------------------

    def _handle_main_key(self, key: int, servers: list) -> bool:
        n = len(servers)
        if key == curses.KEY_UP:
            self._selected = max(0, self._selected - 1)
        elif key == curses.KEY_DOWN:
            self._selected = min(max(0, n - 1), self._selected + 1)
        elif key == 15:   # Ctrl+O
            if servers:
                self._detail = servers[min(self._selected, n - 1)]
                self._detail_scroll = 0
        elif key == 18:   # Ctrl+R
            if servers:
                self._confirm_rollback = True
        elif key in (24, 3, 27):   # Ctrl+X, Ctrl+C, Esc
            return False
        return True

    def _handle_detail_key(self, key: int, data: dict) -> bool:
        if key in (ord("q"), ord("Q"), 27):   # Q / Esc
            self._detail = None
        elif key == curses.KEY_UP:
            self._detail_scroll = max(0, self._detail_scroll - 1)
        elif key == curses.KEY_DOWN:
            lines = data.get("servers", {}).get(self._detail, {}).get("log_lines", [])
            self._detail_scroll = min(
                max(0, len(lines) - 5), self._detail_scroll + 1
            )
        elif key in (24, 3):   # Ctrl+X / Ctrl+C
            return False
        return True

    def _handle_confirm_key(self, key: int, servers: list) -> bool:
        if key in (ord("y"), ord("Y")):
            self._confirm_rollback = False
            if servers and self._selected < len(servers):
                self._start_rollback(servers[self._selected])
        elif key in (ord("n"), ord("N"), 27):
            self._confirm_rollback = False
        elif key in (24, 3):
            return False
        return True

    def _start_rollback(self, server: str):
        snap = None
        if self._state:
            snap = self._state.server_snapshot_path(server)
        if not snap:
            self._status_msg = f"No snapshot available for {_shorten(server)}"
            return

        deploy_user = self._cfg.get("deploy_user", "mwdeploy")
        prod_path = self._cfg.get("prod_path", "/srv/mediawiki")
        log = logging.getLogger("mwdeploy")
        state = self._state

        def _bg():
            ok = do_rollback(server, deploy_user, snap, prod_path, log)
            new_status = S_ROLLBACK if ok else S_FAILED
            msg = "Rolled back" if ok else "Rollback FAILED"
            if state:
                state.update(server, status=new_status, line=msg)
                # Also repool
                _repool_all(self._cfg, server, log)
                state.update(server, line="Repooled after rollback")
            with self._lock:
                self._status_msg = f"{msg}: {_shorten(server)}"

        self._status_msg = f"Rolling back {_shorten(server)}…"
        threading.Thread(target=_bg, daemon=True).start()


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------

def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="mwdeploy",
        description=(
            "MediaWiki deployment tool — wikioasis.org\n\n"
            "Run with no arguments to open the dashboard (shows the last deploy).\n"
            "Pass deployment flags to run a deploy with a live dashboard."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  mwdeploy                                                   # open dashboard
  mwdeploy --versions 1.45 --extension Echo --servers all --rollout
  mwdeploy --config --servers all --rollout
  mwdeploy --rsync --servers all --rollout
  mwdeploy --rsync --servers all --rollout --parallel 2      # deploy 2 at a time
  mwdeploy --provision --servers mw-us-east-031
""",
    )

    what = p.add_argument_group("what to update in staging")
    what.add_argument("--core",      action="store_true",
                      help="git pull root of /srv/mediawiki-staging")
    what.add_argument("--mediawiki", action="store_true",
                      help="git pull MediaWiki core for selected version(s)")
    what.add_argument("--extension", metavar="NAME", action="append", default=[],
                      help="git pull an extension (repeatable; comma-separated ok)")
    what.add_argument("--skin",      metavar="NAME", action="append", default=[],
                      help="git pull a skin (repeatable; comma-separated ok)")
    what.add_argument("--config",    action="store_true",
                      help="git pull /srv/mediawiki-staging/config")

    p.add_argument("--versions", metavar="VERSION",
                   help='version to target, e.g. "1.45" or "all"')
    p.add_argument("--servers",  metavar="SERVERS",
                   help='comma-separated server names or "all"')
    p.add_argument("--rsync",     action="store_true",
                   help="skip git pulls; deploy current staging content")
    p.add_argument("--rollout",   action="store_true",
                   help="depool each server before deploy, repool after")
    p.add_argument("--provision", action="store_true",
                   help="rsync /srv/mediawiki to new servers (no staging sync)")
    p.add_argument("--force",     action="store_true",
                   help="continue even if canary check fails")
    p.add_argument("--parallel",  metavar="N", type=int, default=1,
                   help="deploy to N servers simultaneously (default: 1, serial)")
    p.add_argument("--no-log", dest="no_log", action="store_true",
                   help="terminal only; skip file log and webhook notifications")
    return p


# ---------------------------------------------------------------------------
# Deploy thread
# ---------------------------------------------------------------------------

def _deploy_thread(args, cfg: dict, log: logging.Logger, state: DeployState):
    """Full deployment logic — runs in a background thread."""
    deploy_user = cfg["deploy_user"]
    staging_path = cfg["staging_path"]
    prod_path = cfg["prod_path"]
    canary_vhost = cfg["canary_vhost"]
    target_servers = resolve_servers(args.servers, cfg.get("mw_servers", []))
    staging_server = "localhost"   # represent staging in state

    prompt_lock = threading.Lock()
    abort_event = threading.Event()
    parallel = max(1, getattr(args, "parallel", 1) or 1)

    def _run_server(server):
        return _deploy_server(server, cfg, args, log, state,
                              prompt_lock=prompt_lock, abort_event=abort_event)

    def _run_servers(servers):
        """Serial or parallel deploy loop, honouring abort_event."""
        if parallel <= 1:
            for server in servers:
                ok = _run_server(server)
                if not ok and abort_event.is_set():
                    break
            return

        with concurrent.futures.ThreadPoolExecutor(max_workers=parallel) as pool:
            futures = {pool.submit(_run_server, s): s for s in servers}
            for fut in concurrent.futures.as_completed(futures):
                server = futures[fut]
                try:
                    fut.result()
                except Exception as e:
                    log.error("Unexpected error deploying %s: %s", server, e)
                    state.update(server, status=S_FAILED, line=f"Unexpected error: {e}")
                    if not args.force:
                        abort_event.set()
                # Cancel pending futures if aborted
                if abort_event.is_set() and not args.force:
                    for f in futures:
                        f.cancel()

    try:
        # ── provision mode ────────────────────────────────────────────
        if args.provision:
            _run_servers(target_servers)
            return

        # ── Phase 1: git pulls ────────────────────────────────────────
        if not args.rsync:
            needs_ver = args.mediawiki or args.extension or args.skin
            if needs_ver and not args.versions:
                log.error("--versions required with --mediawiki / --extension / --skin")
                state.mark_done()
                return

            if args.core:
                state.update(staging_server, status=S_RUNNING, line="git pull (core)")
                git_pull(staging_path, log)

            if args.config:
                state.update(staging_server, line="git pull (config)")
                git_pull(os.path.join(staging_path, "config"), log)

            if needs_ver:
                versions = resolve_versions(args.versions, staging_path)
                extensions = [e for g in args.extension for e in g.split(",") if e.strip()]
                skins = [s for g in args.skin for s in g.split(",") if s.strip()]
                for ver in versions:
                    vp = os.path.join(staging_path, "versions", ver)
                    if args.mediawiki:
                        state.update(staging_server, line=f"git pull (mediawiki {ver})")
                        git_pull(vp, log)
                    for ext in extensions:
                        state.update(staging_server, line=f"git pull (extension/{ext})")
                        git_pull(os.path.join(vp, "extensions", ext), log)
                    for skin in skins:
                        state.update(staging_server, line=f"git pull (skin/{skin})")
                        git_pull(os.path.join(vp, "skins", skin), log)
        else:
            state.update(staging_server, status=S_RUNNING, line="--rsync: skipping git pulls")

        # ── Phase 2: local staging sync ───────────────────────────────
        state.update(staging_server, line=f"Syncing {staging_path} → {prod_path}")
        try:
            rsync_local(staging_path, prod_path, log)
            state.update(staging_server, line="Local rsync complete")
        except RuntimeError as e:
            log.error("Local rsync failed: %s", e)
            state.update(staging_server, status=S_FAILED,
                         line=f"Local rsync FAILED: {e}")
            return

        # ── Phase 3: canary on staging ────────────────────────────────
        state.update(staging_server, line="Canary check on localhost…")
        if not canary_check("localhost", canary_vhost, log,
                            deploy_user=deploy_user, force=args.force):
            state.update(staging_server, status=S_FAILED,
                         line="Canary FAILED on staging — deploy aborted")
            return

        state.update(staging_server, status=S_DONE, line="Canary OK")

        if not target_servers:
            return

        # ── Phase 4: rolling deploy ───────────────────────────────────
        if parallel > 1:
            log.info("Parallel deploy: %d workers across %d servers",
                     parallel, len(target_servers))
        _run_servers(target_servers)

    finally:
        state.mark_done()


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = _build_parser()
    args = parser.parse_args()

    cfg = load_config()

    # Build SSH options once
    global _SSH_OPTS
    deploy_user = cfg.get("deploy_user", "mwdeploy")
    ssh_identity = cfg.get("ssh_identity",
                           f"/home/{deploy_user}/.ssh/id_ed25519")
    _SSH_OPTS = [
        "-i", ssh_identity,
        "-o", "StrictHostKeyChecking=no",
        "-o", "BatchMode=yes",
    ]

    deploy_flags = any([
        args.core, args.mediawiki, args.extension, args.skin,
        args.config, args.rsync, args.provision,
    ])

    # ── No deploy flags → open dashboard showing last state ──────────
    if not deploy_flags:
        Dashboard(state=None, cfg=cfg).run()
        return

    # ── Deploy flags → wire up live state + start deploy thread ──────
    log = _setup_logging(cfg, args.no_log)

    target_servers = resolve_servers(args.servers, cfg.get("mw_servers", []))
    all_servers = (["localhost"] + target_servers) if not args.provision else target_servers
    state = DeployState(all_servers)

    _notify(log, cfg, args.no_log,
            f"mwdeploy starting — targets: {target_servers or 'staging only'}")

    t = threading.Thread(
        target=_deploy_thread,
        args=(args, cfg, log, state),
        daemon=True,
    )
    t.start()

    # Run dashboard in main thread (curses must own the terminal)
    Dashboard(state=state, cfg=cfg).run()

    t.join(timeout=5)

    # Final result
    snap = state.snapshot()
    failed = [
        s for s, d in snap["servers"].items()
        if d["status"] == S_FAILED
    ]
    if failed:
        _notify(log, cfg, args.no_log,
                f"DEPLOY FINISHED WITH FAILURES: {failed}", level=logging.ERROR)
        sys.exit(1)
    else:
        _notify(log, cfg, args.no_log,
                f"Deploy complete — {len(all_servers)} server(s) updated")


if __name__ == "__main__":
    main()
