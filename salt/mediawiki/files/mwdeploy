_SSH_OPTS: list[str] = []

S_PENDING  = "pending"
S_RUNNING  = "running"
S_DONE     = "done"
S_FAILED   = "failed"
S_ROLLBACK = "rolled_back"
S_SKIPPED  = "skipped"

_TERMINAL_ST = {S_DONE, S_FAILED, S_ROLLBACK, S_SKIPPED}

_STATUS_ICON: dict[str, str] = {
    S_PENDING:  "○ pending",
    S_RUNNING:  "⟳ running",
